<div 
  class="vt3-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>

  {% if section.settings.heading != blank %}
    <div 
      class="vt3-heading-wrap"
      style="
        max-width: {{ section.settings.heading_max_width }}px;
        padding-left: {{ section.settings.heading_padding }}px;
        padding-right: {{ section.settings.heading_padding }}px;
      "
    >
      <h2 
        class="vt3-heading"
        style="
          font-size: {{ section.settings.heading_size }}px;
          --heading-mobile: {{ section.settings.heading_size_mobile }}px;
        "
      >
        {% assign before = section.settings.heading | split: '[highlight]' | first %}
        {% assign after_split = section.settings.heading | split: '[highlight]' | last | split: '[/highlight]' %}
        {% assign highlight = after_split[0] %}
        {% assign after = after_split[1] %}

        {{ before }}
        <span class="vt3-highlight">{{ highlight }}</span>
        {{ after }}
      </h2>
    </div>
  {% endif %}

  <div class="vt3-container">

    <div class="vt3-grid">

      {% for block in section.blocks %}
        <div class="vt3-card" {{ block.shopify_attributes }}>
          <div class="vt3-media">

            <!-- VIDEO (LAZY LOADED) -->
            {% if block.settings.video != blank %}
              <video 
                class="vt3-video"
                playsinline
                muted
                preload="none"
                width="500"
                height="900"
                data-src="{{ block.settings.video | file_url }}"
              ></video>

              <!-- POSTER -->
              {% if block.settings.image != blank %}
                <div class="vt3-poster">

                  <img
                    src="{{ block.settings.image | image_url: width: 400 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 200 }} 200w,
                      {{ block.settings.image | image_url: width: 300 }} 300w,
                      {{ block.settings.image | image_url: width: 400 }} 400w,
                      {{ block.settings.image | image_url: width: 500 }} 500w
                    "
                    sizes="(max-width: 768px) 100vw, 400px"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="400"
                    height="700"
                  >

                  <button class="vt3-play-btn" type="button" aria-label="Play video">
                    {% render 'video-test-play-icon' %}
                  </button>

                </div>
              {% endif %}

            {% endif %}

          </div>
        </div>
      {% endfor %}

    </div>

    <!-- BUTTONS -->
    <div class="vt-buttons flex flex-wrap justify-center items-center gap-x-[66px] gap-y-[16px] mt-[40px] min-990:mt-[65px]">

      {% if section.settings.golfer_text != blank %}
        <a href="{{ section.settings.golfer_url }}" class="golf-app-hero__button ctm-button button-green button-svg justify-end gap-[42px] pr-[57px] min-w-[337px]">
          {{ section.settings.golfer_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="37" height="20">
            <path d="M0 9.88H35M35 9.88L26 0.88M35 9.88L26 18.88" stroke="currentColor" stroke-width="2.5"/>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.coach_text != blank %}
        <a href="{{ section.settings.coach_url }}" class="golf-app-hero__button ctm-button button-green button-svg justify-end gap-[42px] pr-[57px] min-w-[337px]">
          {{ section.settings.coach_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="37" height="20">
            <path d="M0 9.88H35M35 9.88L26 0.88M35 9.88L26 18.88" stroke="currentColor" stroke-width="2.5"/>
          </svg>
        </a>
      {% endif %}

    </div>

  </div>
</div>

<!-- JS: LAZY LOAD + PLAY -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  document.querySelectorAll('.vt3-card').forEach(card => {

    const poster = card.querySelector('.vt3-poster');
    const video = card.querySelector('.vt3-video');

    if (!poster || !video) return;

    poster.addEventListener('click', function () {

      // Lazy load video source ONLY on click
      if (!video.src) {
        video.src = video.dataset.src;
      }

      poster.style.display = 'none';

      video.setAttribute('controls', true);
      video.play();

    });

  });

});
</script>