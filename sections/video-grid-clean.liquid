<div 
  class="vt3-section"
  style="
    --pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>

  <!-- HEADING -->
  {% if section.settings.heading != blank %}
    <div 
      class="vt3-heading-wrap"
      style="
        --heading-max-desktop: {{ section.settings.heading_max_width_desktop }}px;
        --heading-max-mobile: {{ section.settings.heading_max_width_mobile }}px;
        --heading-pad-desktop: {{ section.settings.heading_padding_desktop }}px;
        --heading-pad-mobile: {{ section.settings.heading_padding_mobile }}px;
      "
    >
      <h2 
        class="vt3-heading vt3-heading-locked"
        style="
          --heading-desktop: {{ section.settings.heading_size_desktop }}px;
          --heading-mobile: {{ section.settings.heading_size_mobile }}px;
        "
      >

        {% assign before = section.settings.heading | split: '–' | first %}
        {% assign after_full = section.settings.heading | split: '–' | last %}

        {% assign highlight_split = after_full | split: '[highlight]' %}
        {% assign after_before_highlight = highlight_split[0] %}
        {% assign highlight_text = highlight_split[1] | split: '[/highlight]' | first %}

        <span class="vt3-line">
          {{ before }} –
        </span>

        <span class="vt3-line">
          {{ after_before_highlight }}
          <span class="vt3-highlight">
            {{ highlight_text }}
          </span>
        </span>

      </h2>
    </div>
  {% endif %}

  <div class="vt3-container">

    <!-- GRID -->
    <div class="vt3-grid">

      {% for block in section.blocks %}
        <div class="vt3-card" {{ block.shopify_attributes }}>
          <div class="vt3-media">

            {% if block.settings.video != blank %}
              {{
                block.settings.video
                | video_tag:
                  controls: true,
                  preload: 'metadata',
                  playsinline: true,
                  class: 'vt3-video',
                  width: 800,
                  height: 1422
              }}

              {% if block.settings.image != blank %}
                <div class="vt3-poster">
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="800"
                    height="1422"
                  >
                </div>
              {% endif %}
            {% endif %}

          </div>
        </div>
      {% endfor %}

    </div>

    <!-- BUTTONS -->
    <div class="vt-buttons flex flex-wrap justify-center items-center gap-x-[66px] gap-y-[16px] mt-[40px] min-990:mt-[65px]">

      {% if section.settings.golfer_text != blank %}
        <a href="{{ section.settings.golfer_url }}" class="golf-app-hero__button ctm-button button-green button-svg gap-[42px] pr-[57px] min-w-[337px]">
          {{ section.settings.golfer_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="37" height="20">
            <path d="M0 9.88H35M35 9.88L26 0.88M35 9.88L26 18.88" stroke="currentColor" stroke-width="2.5"/>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.coach_text != blank %}
        <a href="{{ section.settings.coach_url }}" class="golf-app-hero__button ctm-button button-green button-svg gap-[42px] pr-[57px] min-w-[337px]">
          {{ section.settings.coach_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="37" height="20">
            <path d="M0 9.88H35M35 9.88L26 0.88M35 9.88L26 18.88" stroke="currentColor" stroke-width="2.5"/>
          </svg>
        </a>
      {% endif %}

    </div>

  </div>

</div>