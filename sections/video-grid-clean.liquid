<div class="vt3-section">

  {% if section.settings.heading != blank %}
    <h2 class="vt3-heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="vt3-container">
    <div class="vt3-grid">

      {% for block in section.blocks %}

        <div class="vt3-card" {{ block.shopify_attributes }}>

          <div class="vt3-media">

            {% if block.settings.video != blank %}

              {{
                block.settings.video
                | video_tag:
                  controls: true,
                  preload: 'metadata',
                  class: 'vt3-video',
                  width: 800,
                  height: 1422
              }}

              {% if block.settings.image != blank %}
                <!-- CUSTOM THUMBNAIL (HIGH QUALITY) -->
                <div class="vt3-poster">
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="800"
                    height="1422"
                  >
                  <div class="vt3-play"></div>
                </div>
              {% endif %}

            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  function pauseAll() {
    document.querySelectorAll('.vt3-video').forEach(v => {
      v.pause();
      v.currentTime = 0;
    });

    document.querySelectorAll('.vt3-poster').forEach(p => {
      p.style.display = 'block';
    });
  }

  document.querySelectorAll('.vt3-poster').forEach(poster => {
    const video = poster.parentElement.querySelector('video');

    poster.addEventListener('click', () => {
      pauseAll();
      poster.style.display = 'none';
      video.play().catch(() => {
        poster.style.display = 'block';
      });
    });
  });

});
</script>

{% schema %}
{
  "name": "Video Grid Clean V2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seeing Results – Join Them Today"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Thumbnail image (REQUIRED)" },
        { "type": "text", "id": "name", "label": "Alt text (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Grid Clean V2",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}