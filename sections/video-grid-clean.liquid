<div 
  class="vt3-section"
  style="
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  "
>

  <!-- HEADING -->
  {% if section.settings.heading != blank %}
    <div 
      class="vt3-heading-wrap"
      style="
        max-width: {{ section.settings.heading_max_width_desktop }}px;
        padding-left: {{ section.settings.heading_padding_desktop }}px;
        padding-right: {{ section.settings.heading_padding_desktop }}px;
      "
    >
      <h2 class="vt3-heading vt3-heading-locked">

        {% assign before = section.settings.heading | split: '–' | first %}
        {% assign after = section.settings.heading | split: '–' | last %}

        {% assign highlight = after | split: '[highlight]' | last | split: '[/highlight]' | first %}
        {% assign after_clean = after | split: '[highlight]' | first %}

        <!-- LINE 1 -->
        <span class="vt3-line">
          {{ before }} –
        </span>

        <!-- LINE 2 -->
        <span class="vt3-line">
          {{ after_clean }}
          <span class="vt3-highlight">
            {{ highlight }}
          </span>
        </span>

      </h2>
    </div>
  {% endif %}

  <div class="vt3-container">

    <!-- GRID -->
    <div class="vt3-grid">

      {% for block in section.blocks %}
        <div class="vt3-card" {{ block.shopify_attributes }}>
          <div class="vt3-media">

            {% if block.settings.video != blank %}
              {{
                block.settings.video
                | video_tag:
                  controls: true,
                  preload: 'metadata',
                  playsinline: true,
                  class: 'vt3-video',
                  width: 800,
                  height: 1422
              }}

              {% if block.settings.image != blank %}
                <div class="vt3-poster">
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="800"
                    height="1422"
                  >
                </div>
              {% endif %}

            {% endif %}

          </div>
        </div>
      {% endfor %}

    </div>

    <!-- BUTTONS -->
    <div class="vt-buttons flex flex-wrap justify-center items-center gap-x-[66px] gap-y-[16px] mt-[40px]">

      {% if section.settings.golfer_text != blank %}
        <a href="{{ section.settings.golfer_url }}" class="golf-app-hero__button button-green">
          {{ section.settings.golfer_text }}
        </a>
      {% endif %}

      {% if section.settings.coach_text != blank %}
        <a href="{{ section.settings.coach_url }}" class="golf-app-hero__button button-green">
          {{ section.settings.coach_text }}
        </a>
      {% endif %}

    </div>

  </div>

</div>