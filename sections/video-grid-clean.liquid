<div 
  class="vt3-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {% if section.settings.heading != blank %}
    <h2 class="vt3-heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="vt3-container">

    <!-- VIDEO GRID -->
    <div class="vt3-grid">

      {% for block in section.blocks %}

        <div class="vt3-card" {{ block.shopify_attributes }}>

          <div class="vt3-media">

            {% if block.settings.video != blank %}

              {{
                block.settings.video
                | video_tag:
                  controls: true,
                  preload: 'metadata',
                  playsinline: true,
                  class: 'vt3-video',
                  width: 800,
                  height: 1422
              }}

              {% if block.settings.image != blank %}
                <div class="vt3-poster">
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.name | escape }}"
                    loading="lazy"
                    width="800"
                    height="1422"
                  >
                  <div class="vt3-play"></div>
                </div>
              {% endif %}

            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

    <!-- CTA BUTTONS -->
    <div class="vt3-buttons">

      {% if section.settings.golfer_text != blank %}
        <a 
          href="{{ section.settings.golfer_url }}" 
          class="vt3-btn"
          style="
            background: {{ section.settings.button_bg }};
            color: {{ section.settings.button_text }};
          "
        >
          {{ section.settings.golfer_text }}
          <span class="vt3-arrow">→</span>
        </a>
      {% endif %}

      {% if section.settings.coach_text != blank %}
        <a 
          href="{{ section.settings.coach_url }}" 
          class="vt3-btn"
          style="
            background: {{ section.settings.button_bg }};
            color: {{ section.settings.button_text }};
          "
        >
          {{ section.settings.coach_text }}
          <span class="vt3-arrow">→</span>
        </a>
      {% endif %}

    </div>

  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  function pauseAll() {
    document.querySelectorAll('.vt3-video').forEach(v => {
      v.pause();
      v.currentTime = 0;
    });

    document.querySelectorAll('.vt3-poster').forEach(p => {
      p.style.display = 'block';
    });
  }

  document.querySelectorAll('.vt3-poster').forEach(poster => {
    const video = poster.parentElement.querySelector('video');

    poster.addEventListener('click', () => {
      pauseAll();
      poster.style.display = 'none';

      video.play().catch(() => {
        poster.style.display = 'block';
      });
    });
  });

});
</script>

{% schema %}
{
  "name": "Video Grid Clean V2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    },

    {
      "type": "text",
      "id": "golfer_text",
      "label": "Golfer Button Text",
      "default": "I'M A GOLFER"
    },
    {
      "type": "url",
      "id": "golfer_url",
      "label": "Golfer Button Link"
    },
    {
      "type": "text",
      "id": "coach_text",
      "label": "Coach Button Text",
      "default": "I'M A COACH"
    },
    {
      "type": "url",
      "id": "coach_url",
      "label": "Coach Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#0A7A28"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Thumbnail" },
        { "type": "text", "id": "name", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Grid Clean V2",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}