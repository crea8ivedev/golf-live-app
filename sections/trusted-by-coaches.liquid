{% comment %}
  Section: Trusted by Coaches (FIXED MOBILE + CLEAN)
{% endcomment %}

<section class="trusted-coaches color-{{ section.settings.color_scheme }}">
  <div class="trusted-coaches__inner">

    <!-- HEADING -->
    <div class="trusted-coaches__header">
      {% if section.settings.heading != blank %}
        <h2 class="trusted-coaches__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="trusted-coaches__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <!-- GRID -->
    <div class="trusted-coaches__grid">

      {% for block in section.blocks %}
        <div class="trusted-coaches__card" {{ block.shopify_attributes }}>

          {% assign coach_image = block.settings.player_image %}

          {% if block.settings.player_image_mobile != blank %}
            {% assign coach_image = block.settings.player_image_mobile %}
          {% endif %}

          {% if coach_image != blank %}
            {{
              coach_image
              | image_url: width: 600
              | image_tag:
                class: 'trusted-coaches__image',
                loading: 'lazy',
                widths: '300,400,600',
                sizes: '(max-width: 768px) 50vw, 20vw',
                alt: block.settings.player_name
            }}
          {% endif %}

          {% if block.settings.player_name != blank %}
            <div class="trusted-coaches__overlay">
              <div class="trusted-coaches__name">
                {{ block.settings.player_name }}
              </div>
            </div>
          {% endif %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trusted Coaches",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Top Coaches"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From PGA Tour coaches to rising instructors – trusted by the best."
    }
  ],
  "blocks": [
    {
      "type": "player",
      "name": "Coach",
      "settings": [
        {
          "type": "image_picker",
          "id": "player_image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "player_image_mobile",
          "label": "Optional Mobile Image"
        },
        {
          "type": "richtext",
          "id": "player_name",
          "label": "Coach Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Coaches",
      "blocks": [
        { "type": "player" },
        { "type": "player" },
        { "type": "player" },
        { "type": "player" }
      ]
    }
  ]
}
{% endschema %}