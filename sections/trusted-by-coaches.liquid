{% comment %}
  Section: Trusted by Coaches (FINAL FIX)
{% endcomment %}

<style>
/* =========================
   SECTION SPACING
========================= */
.trusted-coaches {
  padding: 80px 20px 60px;
  color: #fff;
}

/* =========================
   HEADER (FIXED)
========================= */
.trusted-coaches-details {
  text-align: center;
  margin-bottom: 40px;
  position: relative !important;
  top: auto !important;
  transform: none !important;
}

/* TEXT */
.trusted-coaches__heading {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 10px;
}

.trusted-coaches__subheading {
  font-size: 16px;
  opacity: 0.8;
  max-width: 600px;
  margin: 0 auto;
}

/* =========================
   GRID
========================= */
.trusted-coaches__grid {
  display: flex;
  flex-wrap: wrap;
}

/* DESKTOP */
@media (min-width: 990px) {
  .trusted-coaches__card {
    flex: 0 0 20%;
  }
}

/* MOBILE */
@media (max-width: 989px) {
  .trusted-coaches__card {
    flex: 0 0 50%;
  }
}

/* =========================
   CARD
========================= */
.trusted-coaches__card {
  position: relative;
  overflow: hidden;
}

/* =========================
   IMAGE CONTROL (NO DUPES)
========================= */
.trusted-coaches__mobile {
  display: none;
}

@media (max-width: 989px) {
  .trusted-coaches__desktop {
    display: none;
  }
  .trusted-coaches__mobile {
    display: block;
  }
}

/* IMAGE */
.trusted-coaches__image {
  width: 100%;
  height: auto;
  display: block;
}

/* =========================
   OVERLAY
========================= */
.trusted-coaches__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 14px;

  background: linear-gradient(
    to top,
    rgba(0,0,0,0.7),
    rgba(0,0,0,0)
  );
}

.trusted-coaches__name {
  font-weight: 700;
  font-size: 14px;
}
</style>

<section class="trusted-coaches color-{{ section.settings.color_scheme }}">
  <div class="rusted-coaches-inside">

    <!-- HEADER -->
    <div class="trusted-coaches-details">

      {% if section.settings.heading != blank %}
        <h2 class="trusted-coaches__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="trusted-coaches__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

    </div>

    <!-- GRID -->
    <div class="trusted-coaches__grid">

      {% for block in section.blocks %}
        <div class="trusted-coaches__card" {{ block.shopify_attributes }}>

          <!-- DESKTOP -->
          {% if block.settings.player_image != blank %}
            <div class="trusted-coaches__desktop">
              {{
                block.settings.player_image
                | image_url: width: 600
                | image_tag:
                  class: 'trusted-coaches__image',
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 50vw, 20vw',
                  alt: block.settings.player_name
              }}
            </div>
          {% endif %}

          <!-- MOBILE -->
          {% if block.settings.player_image_mobile != blank %}
            <div class="trusted-coaches__mobile">
              {{
                block.settings.player_image_mobile
                | image_url: width: 400
                | image_tag:
                  class: 'trusted-coaches__image',
                  loading: 'lazy',
                  widths: '200,300,400',
                  sizes: '50vw',
                  alt: block.settings.player_name
              }}
            </div>
          {% endif %}

          <!-- NAME -->
          {% if block.settings.player_name != blank %}
            <div class="trusted-coaches__overlay">
              <div class="trusted-coaches__name">
                {{ block.settings.player_name }}
              </div>
            </div>
          {% endif %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>