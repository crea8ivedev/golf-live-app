{% comment %}
  Section: Trusted by Coaches (CLEAN + FIXED)
{% endcomment %}

<style>
/* =========================
   SECTION SPACING FIX
========================= */
.trusted-coaches {
  padding: 80px 20px 60px;
  color: #ffffff;
}

/* =========================
   HEADER FIX (NO ABSOLUTE)
========================= */
.trusted-coaches-details {
  position: relative !important;
  top: auto !important;
  transform: none !important;
  margin-bottom: 40px;
}

/* =========================
   TEXT COLOR
========================= */
.trusted-coaches__heading,
.trusted-coaches__subheading,
.trusted-coaches__name {
  color: #ffffff !important;
}

/* =========================
   GRID FIX
========================= */
.trusted-coaches__grid {
  display: flex;
  flex-wrap: wrap;
}

/* =========================
   CARD
========================= */
.trusted-coaches__card {
  position: relative;
  overflow: hidden;
}

/* Desktop columns */
@media (min-width: 990px) {
  .trusted-coaches__card {
    flex: 0 0 20%;
  }
}

/* Tablet */
@media (max-width: 989px) {
  .trusted-coaches__card {
    flex: 0 0 50%;
  }
}

/* =========================
   IMAGE CONTROL (NO DUPES)
========================= */
.trusted-coaches__mobile {
  display: none;
}

@media (max-width: 989px) {
  .trusted-coaches__desktop {
    display: none;
  }
  .trusted-coaches__mobile {
    display: block;
  }
}

/* =========================
   IMAGE STABILITY
========================= */
.trusted-coaches__image {
  width: 100%;
  height: auto;
  display: block;
}

/* =========================
   OVERLAY (CLEAN)
========================= */
.trusted-coaches__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;

  background: linear-gradient(
    to top,
    rgba(0,0,0,0.75),
    rgba(0,0,0,0)
  );
}

.trusted-coaches__name {
  font-weight: 700;
  font-size: 14px;
  line-height: 1.2;
}
</style>

<section class="trusted-coaches color-{{ section.settings.color_scheme }}">
  <div class="rusted-coaches-inside">

    <!-- HEADER -->
    <div class="trusted-coaches-details px-[28px] text-center">

      {% if section.settings.heading != blank %}
        <h2 class="trusted-coaches__heading mb-[12px]">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="trusted-coaches__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

    </div>

    <!-- GRID -->
    <div class="trusted-coaches__grid">

      {% for block in section.blocks %}
        <div
          class="trusted-coaches__card"
          {{ block.shopify_attributes }}
        >

          <!-- DESKTOP IMAGE -->
          {% if block.settings.player_image != blank %}
            <div class="trusted-coaches__desktop">
              {{
                block.settings.player_image
                | image_url: width: 600
                | image_tag:
                  class: 'trusted-coaches__image',
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 50vw, 20vw',
                  alt: block.settings.player_name
              }}
            </div>
          {% endif %}

          <!-- MOBILE IMAGE -->
          {% if block.settings.player_image_mobile != blank %}
            <div class="trusted-coaches__mobile">
              {{
                block.settings.player_image_mobile
                | image_url: width: 400
                | image_tag:
                  class: 'trusted-coaches__image',
                  loading: 'lazy',
                  widths: '200,300,400',
                  sizes: '50vw',
                  alt: block.settings.player_name
              }}
            </div>
          {% endif %}

          <!-- NAME -->
          {% if block.settings.player_name != blank %}
            <div class="trusted-coaches__overlay">
              <div class="trusted-coaches__name">
                {{ block.settings.player_name }}
              </div>
            </div>
          {% endif %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trusted by Coaches",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Top Coaches"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From PGA Tour coaches to rising instructors – trusted by the best."
    }
  ],
  "blocks": [
    {
      "type": "player",
      "name": "Player",
      "settings": [
        {
          "type": "image_picker",
          "id": "player_image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "player_image_mobile",
          "label": "Mobile Image"
        },
        {
          "type": "richtext",
          "id": "player_name",
          "label": "Player Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted by Coaches"
    }
  ]
}
{% endschema %}