{% comment %}
  Section: Golf Live Comparison (FINAL FIXED)
{% endcomment %}

<style>
/* =========================
   LAYOUT
========================= */

.glc-inner {
  display: flex;
  align-items: center;
  gap: 30px;
}

/* Reverse layout for grey card */
.glc-inner.reverse {
  flex-direction: row-reverse;
}

/* =========================
   WIDTH CONTROL
========================= */

.glc-phone {
  width: 45%;
}

.glc-content {
  width: 55%;
}

/* =========================
   IMAGE
========================= */

.glc-phone img {
  width: 100%;
  max-width: 320px;
  height: auto;
  display: block;
}

/* =========================
   TEXT
========================= */

.glc-card-title {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 20px;
  text-align: left;
}

/* =========================
   LIST
========================= */

.glc-list {
  padding: 0;
  margin: 0;
  list-style: none;
}

.glc-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
  text-align: left;
}

.glc-item-icon {
  width: 22px;
  height: 22px;
  min-width: 22px;
  margin-top: 3px;
}

/* =========================
   COLORS
========================= */

.glc-green {
  background: #2f6f3e;
  color: #fff;
  border-radius: 28px;
  padding: 60px 40px;
}

.glc-grey {
  background: #f4f4f4;
  border-radius: 28px;
  padding: 60px 40px;
}

/* =========================
   MOBILE (🔥 FIXED)
========================= */

@media (max-width: 749px) {

  /* KEEP SIDE-BY-SIDE */
  .glc-inner {
    flex-direction: row !important;
    gap: 16px;
  }

  .glc-inner.reverse {
    flex-direction: row-reverse !important;
  }

  .glc-phone {
    width: 45%;
  }

  .glc-content {
    width: 55%;
  }

  /* CENTER + BIGGER TITLE */
  .glc-card-title {
    text-align: center;
    font-size: 26px;
    margin-bottom: 14px;
  }

  .glc-item {
    font-size: 14px;
  }
}
</style>

<section class="golf-live-compare">
  <div class="container-136">

    {% if section.settings.heading != blank %}
      <h2 class="text-center text-[36px] font-bold mb-[10px]">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="text-center text-[18px] mb-[40px] max-w-[700px] mx-auto text-[#555]">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    <div class="flex gap-[40px] max-990:flex-wrap">

      <!-- GREEN -->
      <div class="glc-green w-full 990:w-1/2">
        <div class="glc-inner">

          <!-- IMAGE LEFT -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.green_phone | image_url: width: 600 }}"
                alt="With Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">
              {{ section.settings.green_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        class="glc-item-icon"
                        width="22"
                        height="22"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

      <!-- GREY -->
      <div class="glc-grey w-full 990:w-1/2">
        <div class="glc-inner reverse">

          <!-- IMAGE RIGHT -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.grey_phone | image_url: width: 600 }}"
                alt="Without Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">
              {{ section.settings.grey_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        class="glc-item-icon"
                        width="22"
                        height="22"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Golf Live Comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "image_picker", "id": "green_phone", "label": "Green Phone Image" },
    { "type": "text", "id": "green_title", "label": "Green Title", "default": "With Golf Live" },
    { "type": "image_picker", "id": "grey_phone", "label": "Grey Phone Image" },
    { "type": "text", "id": "grey_title", "label": "Grey Title", "default": "Without Golf Live" }
  ],
  "blocks": [
    {
      "type": "with_item",
      "name": "With Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "without_item",
      "name": "Without Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Live Comparison" }
  ]
}
{% endschema %}