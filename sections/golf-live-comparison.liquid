{% comment %}
  Golf Live Comparison – Optimized + Animated + Responsive
{% endcomment %}

<section 
  class="golf-live-compare"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container-136">

    {% if section.settings.heading != blank %}
      <h2 class="glc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="glc-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="glc-grid">

      <!-- WITH GOLF LIVE -->
      <div class="glc-card glc-green">

        <div class="glc-inner">

          <!-- PHONE -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.green_phone | image_url: width: 600 }}"
                srcset="
                  {{ section.settings.green_phone_mobile | image_url: width: 400 }} 400w,
                  {{ section.settings.green_phone | image_url: width: 600 }} 600w
                "
                sizes="(max-width: 749px) 100vw, 40vw"
                alt="With Golf Live"
                loading="lazy"
                width="600"
                height="900"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3>{{ section.settings.green_title }}</h3>

            <ul>
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 40 }}" alt="">
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

      <!-- WITHOUT GOLF LIVE -->
      <div class="glc-card glc-grey">

        <div class="glc-inner">

          <!-- TEXT -->
          <div class="glc-content">
            <h3>{{ section.settings.grey_title }}</h3>

            <ul>
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 40 }}" alt="">
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

          <!-- PHONE -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.grey_phone | image_url: width: 600 }}"
                srcset="
                  {{ section.settings.grey_phone_mobile | image_url: width: 400 }} 400w,
                  {{ section.settings.grey_phone | image_url: width: 600 }} 600w
                "
                sizes="(max-width: 749px) 100vw, 40vw"
                alt="Without Golf Live"
                loading="lazy"
                width="600"
                height="900"
              >
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>

<!-- =========================
  STYLES
========================= -->
<style>
.golf-live-compare {
  text-align: center;
}

.glc-heading {
  font-size: 40px;
  font-weight: 700;
}

.glc-subheading {
  max-width: 700px;
  margin: 10px auto 40px;
}

.glc-grid {
  display: flex;
  gap: 30px;
}

.glc-card {
  flex: 1;
  border-radius: 24px;
  overflow: hidden;
  padding: 40px;
}

.glc-green {
  background: #2f6f3a;
  color: #fff;
}

.glc-grey {
  background: #f4f4f4;
}

.glc-inner {
  display: flex;
  align-items: center;
  gap: 30px;
}

.glc-phone {
  flex: 1;
  animation: float 4s ease-in-out infinite;
}

.glc-phone img {
  width: 100%;
  height: auto;
}

.glc-content {
  flex: 1;
  text-align: left;
}

.glc-content h3 {
  font-size: 24px;
  margin-bottom: 20px;
}

.glc-content ul {
  list-style: none;
  padding: 0;
}

.glc-content li {
  display: flex;
  gap: 10px;
  margin-bottom: 15px;
  align-items: center;
}

/* FLOATING ANIMATION */
@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0px); }
}

/* MOBILE FIX */
@media (max-width: 749px) {
  .glc-grid {
    flex-direction: column;
  }

  .glc-inner {
    flex-direction: column;
    text-align: center;
  }

  .glc-content {
    text-align: center;
  }

  .glc-heading {
    font-size: 28px;
  }
}
</style>

<!-- =========================
  SCROLL ANIMATION
========================= -->
<script>
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.style.opacity = 1;
      entry.target.style.transform = 'translateY(0)';
    }
  });
});

document.querySelectorAll('.glc-card').forEach(el => {
  el.style.opacity = 0;
  el.style.transform = 'translateY(40px)';
  el.style.transition = 'all 0.6s ease';
  observer.observe(el);
});
</script>

{% schema %}
{
  "name": "Golf Live Comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },

    { "type": "image_picker", "id": "green_phone", "label": "Green Phone Desktop" },
    { "type": "image_picker", "id": "green_phone_mobile", "label": "Green Phone Mobile" },
    { "type": "text", "id": "green_title", "label": "Green Title", "default": "With Golf Live" },

    { "type": "image_picker", "id": "grey_phone", "label": "Grey Phone Desktop" },
    { "type": "image_picker", "id": "grey_phone_mobile", "label": "Grey Phone Mobile" },
    { "type": "text", "id": "grey_title", "label": "Grey Title", "default": "Without Golf Live" },

    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 10, "default": 60, "label": "Padding Top" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 10, "default": 60, "label": "Padding Bottom" }
  ],
  "blocks": [
    {
      "type": "with_item",
      "name": "With Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "without_item",
      "name": "Without Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Live Comparison" }
  ]
}
{% endschema %}