{% comment %}
  Section: Golf Live Comparison (STABLE FIX)
{% endcomment %}

<style>
/* =========================
  LAYOUT FIX
========================= */

.glc-card {
  border-radius: 28px;
  overflow: hidden;
  padding: 60px 40px;
}

.glc-green {
  background: #2f6f3e;
  color: #fff;
}

.glc-grey {
  background: #f4f4f4;
}

/* FLEX */
.glc-row {
  display: flex;
  align-items: center;
  gap: 30px;
}

/* ONLY grey flips */
.glc-row--reverse {
  flex-direction: row-reverse;
}

/* WIDTHS */
.glc-phone { width: 45%; }
.glc-content { width: 55%; }

/* IMAGE */
.glc-phone img {
  width: 100%;
  max-width: 320px;
  height: auto;
  display: block;
}

/* TEXT */
.glc-card-title {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 20px;
  text-align: left;
}

/* LIST */
.glc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.glc-item {
  display: flex;
  gap: 12px;
  margin-bottom: 14px;
  align-items: flex-start;
}

.glc-item img {
  width: 26px;
  height: 26px;
  min-width: 26px;
  margin-top: 4px;
}

/* MOBILE */
@media (max-width: 749px) {
  .glc-row {
    flex-direction: row;
    gap: 16px;
  }

  .glc-phone { width: 40%; }
  .glc-content { width: 60%; }

  .glc-card-title {
    text-align: center;
    font-size: 24px;
  }
}
</style>

<section class="golf-live-compare">
  <div class="container-136">

    {% if section.settings.heading != blank %}
      <h2 class="text-center text-[36px] font-bold mb-[10px]">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="text-center text-[18px] mb-[40px] max-w-[700px] mx-auto text-[#555]">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    <div class="flex gap-[40px] max-990:flex-wrap">

      <!-- GREEN -->
      <div class="glc-card glc-green w-full 990:w-1/2">
        <div class="glc-row">

          <!-- IMAGE LEFT -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.green_phone | image_url: width: 600 }}"
                alt="With Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">
              {{ section.settings.green_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        width="26"
                        height="26"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

      <!-- GREY -->
      <div class="glc-card glc-grey w-full 990:w-1/2">
        <div class="glc-row glc-row--reverse">

          <!-- IMAGE RIGHT -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.grey_phone | image_url: width: 600 }}"
                alt="Without Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">
              {{ section.settings.grey_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        width="26"
                        height="26"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>