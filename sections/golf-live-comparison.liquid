{% comment %}
  Section: Golf Live Comparison (FIXED ORIENTATION)
{% endcomment %}

<style>
/* =========================
  PHONE VISIBILITY
========================= */

.golf-live-compare .glc-phone--mobile { display: none; }
.golf-live-compare .glc-phone--desktop { display: block; }

@media (max-width: 749px) {
  .golf-live-compare .glc-phone--desktop { display: none; }
  .golf-live-compare .glc-phone--mobile { display: block; }
}

/* =========================
  FLEX LAYOUT
========================= */

.glc-row {
  display: flex;
  align-items: center;
  gap: 23px;
}

/* ONLY grey flips */
@media (min-width: 990px) {
  .glc-row--reverse {
    flex-direction: row-reverse;
  }
}

/* =========================
  WIDTHS
========================= */

.glc-phone { flex: 0 0 45%; }
.glc-phone-sibling { flex: 0 0 55%; }

/* Mobile balance */
@media (max-width: 749px) {
  .glc-phone { flex: 0 0 40%; }
  .glc-phone-sibling { flex: 0 0 60%; padding-left: 12px; }
}

/* =========================
  TEXT
========================= */

.glc-phone-sibling {
  text-align: left !important;
}

.glc-list {
  text-align: left;
  margin-top: 20px;
}

/* =========================
  ICON CONSISTENCY
========================= */

.glc-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}

.glc-list img {
  width: 26px;
  height: 26px;
  min-width: 26px;
  object-fit: contain;
  margin-top: 4px;
}

.glc-list span {
  line-height: 1.5;
}

/* Prevent layout shift */
.glc-phone img {
  width: 100%;
  height: auto;
  display: block;
}
</style>

<section class="golf-live-compare" id="section-{{ section.id }}">
  <div class="container-136 max-sm:!px-0">

    <div class="max-sm:!px-[24px]">
      {% if section.settings.heading != blank %}
        <h2 class="glc-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="glc-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="glc-grid flex gap-[44px] max-xl:gap-[30px] max-sm:gap-0 max-990:flex-wrap">

      <!-- GREEN (IMAGE LEFT ✅) -->
      <div class="glc-card glc-green 990:w-1/2 w-full rounded-[28px] py-14 pr-9 pl-0">

        <div class="glc-row">

          <!-- IMAGE LEFT -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone glc-phone--desktop">
              {{
                section.settings.green_phone
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 40vw, 45vw',
                  alt: 'With Golf Live'
              }}
            </div>
          {% endif %}

          {% if section.settings.green_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile">
              {{
                section.settings.green_phone_mobile
                | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,500',
                  sizes: '40vw',
                  alt: 'With Golf Live'
              }}
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-phone-sibling text-white">
            <h3 class="glc-card-title text-white">
              {{ section.settings.green_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      {{
                        block.settings.icon
                        | image_url: width: 40
                        | image_tag:
                          loading: 'lazy',
                          widths: '40,60',
                          sizes: '26px',
                          alt: ''
                      }}
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

      <!-- GREY (IMAGE RIGHT ✅) -->
      <div class="glc-card glc-grey 990:w-1/2 w-full rounded-[28px] py-12 pl-[50px] pr-0">

        <div class="glc-row glc-row--reverse">

          <!-- IMAGE -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone glc-phone--desktop">
              {{
                section.settings.grey_phone
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 40vw, 45vw',
                  alt: 'Without Golf Live'
              }}
            </div>
          {% endif %}

          {% if section.settings.grey_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile">
              {{
                section.settings.grey_phone_mobile
                | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,500',
                  sizes: '40vw',
                  alt: 'Without Golf Live'
              }}
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-phone-sibling text-left">
            <h3 class="glc-card-title text-black">
              {{ section.settings.grey_title }}
            </h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      {{
                        block.settings.icon
                        | image_url: width: 40
                        | image_tag:
                          loading: 'lazy',
                          widths: '40,60',
                          sizes: '26px',
                          alt: ''
                      }}
                    {% endif %}
                    <span class="text-black">{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Golf Live Comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading" },
    { "type": "textarea", "id": "subheading", "label": "Section Subheading" },
    { "type": "image_picker", "id": "green_phone", "label": "Green Phone Image" },
    { "type": "image_picker", "id": "green_phone_mobile", "label": "Green Phone Image (Mobile)" },
    { "type": "text", "id": "green_title", "label": "Green Title" },
    { "type": "image_picker", "id": "grey_phone", "label": "Grey Phone Image" },
    { "type": "image_picker", "id": "grey_phone_mobile", "label": "Grey Phone Image (Mobile)" },
    { "type": "text", "id": "grey_title", "label": "Grey Title" }
  ],
  "blocks": [
    {
      "type": "with_item",
      "name": "With Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon Image" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "without_item",
      "name": "Without Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon Image" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Live Comparison" }
  ]
}
{% endschema %}