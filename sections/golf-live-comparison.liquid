{% comment %}
  Section: Golf Live Comparison
  Theme: Dawn
{% endcomment %}

<style>
  /* =========================
    Phone Visibility
  ========================= */

  .golf-live-compare .glc-phone--mobile { display: none; }
  .golf-live-compare .glc-phone--desktop { display: block; }

  @media (max-width: 749px) {
    .golf-live-compare .glc-phone--desktop { display: none; }
    .golf-live-compare .glc-phone--mobile { display: block; }
  }

  /* =========================
    Layout Fix (KEY)
  ========================= */

  .glc-inner {
    display: flex;
    align-items: center;
    gap: 23px;
    width: 100%;
  }

  /* GREEN SECTION → REVERSED */
  .glc-inner--reverse {
    flex-direction: row-reverse;
  }

  /* MOBILE STACK */
  @media (max-width: 749px) {
    .glc-inner,
    .glc-inner--reverse {
      flex-direction: column;
      text-align: center;
    }

    .glc-phone {
      width: 100% !important;
      max-width: 260px;
      margin: 0 auto;
    }

    .glc-phone-sibling {
      width: 100% !important;
      text-align: center !important;
      margin-top: 20px !important;
    }
  }

  /* IMAGE SAFETY (prevents collapse) */
  .glc-phone img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

<section class="golf-live-compare" id="section-{{ section.id }}">
  <div class="container-136 max-sm:!px-0">

    <div class="max-sm:!px-[24px]">
      {% if section.settings.heading != blank %}
        <h2 class="glc-heading scroll-trigger animate--slide-in">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="glc-subheading scroll-trigger animate--slide-in">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <div class="glc-grid flex items-stretch gap-[44px] max-xl:gap-[30px] max-sm:gap-0 max-990:flex-wrap">

      <!-- =========================
        WITH GOLF LIVE (GREEN)
        ✅ FIXED: reversed layout
      ========================= -->
      <div
        class="glc-card glc-green 990:w-1/2 w-full relative bg-cover bg-top bg-no-repeat overflow-hidden pr-9 py-14 pl-0 rounded-[28px]"
        style="{% if section.settings.green_bg != blank %}background-image:url({{ section.settings.green_bg | image_url }});{% endif %}"
      >

        <div class="glc-inner glc-inner--reverse">

          <!-- PHONE -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone glc-phone--desktop w-[45%] max-sm:w-1/2 scroll-trigger animate--slide-in">
              <img
                src="{{ section.settings.green_phone | image_url: width: 600 }}"
                alt="With Golf Live App"
                loading="lazy"
                width="600"
                height="900"
              >
            </div>
          {% endif %}

          {% if section.settings.green_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile w-[45%] max-sm:w-1/2 scroll-trigger animate--slide-in">
              <img
                src="{{ section.settings.green_phone_mobile | image_url: width: 500 }}"
                alt="With Golf Live App"
                loading="lazy"
                width="500"
                height="800"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-phone-sibling flex flex-col w-3/5 max-sm:w-1/2 text-white text-left mt-[80px] max-sm:mt-[20px]">

            <h3 class="glc-card-title text-white scroll-trigger animate--slide-in">
              {{ section.settings.green_title }}
            </h3>

            <ul class="glc-list mt-[32px]">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li class="glc-item glc-item--check text-white scroll-trigger animate--slide-in" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 40 }}" alt="" loading="lazy">
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

          </div>
        </div>
      </div>

      <!-- =========================
        WITHOUT GOLF LIVE (GREY)
      ========================= -->
      <div
        class="glc-card glc-grey 990:w-1/2 w-full relative bg-cover bg-top bg-no-repeat overflow-hidden pl-[50px] max-xl:pl-[22px] py-12 pr-0 rounded-[28px]"
        style="{% if section.settings.grey_bg != blank %}background-image:url({{ section.settings.grey_bg | image_url }});{% endif %}"
      >

        <div class="glc-inner">

          <!-- TEXT -->
          <div class="glc-phone-sibling flex flex-col w-3/5 max-sm:w-1/2 text-left mt-[80px] max-sm:mt-[20px]">

            <h3 class="glc-card-title text-black scroll-trigger animate--slide-in">
              {{ section.settings.grey_title }}
            </h3>

            <ul class="glc-list mt-[32px]">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li class="glc-item glc-item--cross scroll-trigger animate--slide-in" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 40 }}" alt="" loading="lazy">
                    {% endif %}
                    <span class="text-black">{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

          </div>

          <!-- PHONE -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone glc-phone--desktop w-[45%] max-sm:w-1/2 scroll-trigger animate--slide-in">
              <img
                src="{{ section.settings.grey_phone | image_url: width: 600 }}"
                alt="Without Golf Live"
                loading="lazy"
                width="600"
                height="900"
              >
            </div>
          {% endif %}

          {% if section.settings.grey_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile w-[45%] max-sm:w-1/2 scroll-trigger animate--slide-in">
              <img
                src="{{ section.settings.grey_phone_mobile | image_url: width: 500 }}"
                alt="Without Golf Live"
                loading="lazy"
                width="500"
                height="800"
              >
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>