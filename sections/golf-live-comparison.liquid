{% comment %}
  Section: Golf Live Comparison (Upgraded SaaS Version)
{% endcomment %}

<style>
/* =========================
   BASE STYLES
========================= */

.glc-heading {
  font-size: 36px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 10px;
}

.glc-subheading {
  text-align: center;
  font-size: 18px;
  max-width: 700px;
  margin: 0 auto 40px;
  color: #555;
}

/* =========================
   CARD STYLES
========================= */

.glc-card {
  border-radius: 28px;
  padding: 60px 40px;
}

.glc-green {
  background: #2f6f3e;
  color: #fff;
}

.glc-grey {
  background: #f4f4f4;
}

/* =========================
   FLEX LAYOUT
========================= */

.glc-inner {
  display: flex;
  align-items: center;
  gap: 30px;
}

.glc-inner.reverse {
  flex-direction: row-reverse;
}

/* =========================
   PHONE IMAGE
========================= */

.glc-phone img {
  width: 100%;
  max-width: 320px;
  height: auto;
}

/* =========================
   CONTENT
========================= */

.glc-content {
  flex: 1;
}

.glc-card-title {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 20px;
  text-align: left;
}

/* =========================
   LIST ITEMS
========================= */

.glc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.glc-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 18px;
  font-size: 16px;
  line-height: 1.4;
  text-align: left;
}

/* ICONS — FIXED SIZE */
.glc-item-icon {
  width: 22px;
  height: 22px;
  min-width: 22px;
  margin-top: 3px;
}

/* =========================
   MOBILE STYLES
========================= */

@media (max-width: 749px) {

  .glc-inner {
    flex-direction: column !important;
    text-align: center;
  }

  .glc-content {
    width: 100%;
  }

  .glc-card-title {
    text-align: center !important;
    font-size: 30px;
  }

  .glc-item {
    text-align: left;
  }

  .glc-phone img {
    max-width: 260px;
    margin-bottom: 20px;
  }

}
</style>

<section class="golf-live-compare">
  <div class="container-136">

    {% if section.settings.heading != blank %}
      <h2 class="glc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="glc-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="glc-grid flex gap-[40px] max-990:flex-wrap">

      <!-- WITH GOLF LIVE -->
      <div class="glc-card glc-green w-full 990:w-1/2">
        <div class="glc-inner">

          <!-- IMAGE LEFT -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.green_phone | image_url: width: 600 }}"
                alt="With Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">{{ section.settings.green_title }}</h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        class="glc-item-icon"
                        width="22"
                        height="22"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

      <!-- WITHOUT GOLF LIVE -->
      <div class="glc-card glc-grey w-full 990:w-1/2">
        <div class="glc-inner reverse">

          <!-- IMAGE RIGHT -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone">
              <img
                src="{{ section.settings.grey_phone | image_url: width: 600 }}"
                alt="Without Golf Live"
                width="320"
                height="640"
                loading="lazy"
              >
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-content">
            <h3 class="glc-card-title">{{ section.settings.grey_title }}</h3>

            <ul class="glc-list">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li class="glc-item">
                    {% if block.settings.icon != blank %}
                      <img
                        src="{{ block.settings.icon | image_url: width: 40 }}"
                        alt=""
                        class="glc-item-icon"
                        width="22"
                        height="22"
                      >
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Golf Live Comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },

    { "type": "image_picker", "id": "green_phone", "label": "Green Phone Image" },
    { "type": "text", "id": "green_title", "label": "Green Title", "default": "With Golf Live" },

    { "type": "image_picker", "id": "grey_phone", "label": "Grey Phone Image" },
    { "type": "text", "id": "grey_title", "label": "Grey Title", "default": "Without Golf Live" }
  ],
  "blocks": [
    {
      "type": "with_item",
      "name": "With Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "without_item",
      "name": "Without Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Live Comparison" }
  ]
}
{% endschema %}