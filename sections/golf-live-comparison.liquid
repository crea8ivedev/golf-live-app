{% comment %}
  Section: Golf Live Comparison
  Theme: Dawn
{% endcomment %}

<style>
  /* =========================
    Phone Visibility
  ========================= */

  .golf-live-compare .glc-phone--mobile { display: none; }
  .golf-live-compare .glc-phone--desktop { display: block; }

  @media (max-width: 749px) {
    .golf-live-compare .glc-phone--desktop { display: none; }
    .golf-live-compare .glc-phone--mobile { display: block; }
  }

  /* =========================
    Reverse Green Layout
  ========================= */

  @media (min-width: 990px) {
    .glc-reverse {
      flex-direction: row-reverse;
    }
  }

  @media (max-width: 989px) {
    .glc-reverse {
      flex-direction: column;
    }
  }

  /* Prevent layout shift */
  .glc-phone img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

<section class="golf-live-compare" id="section-{{ section.id }}">
  <div class="container-136 max-sm:!px-0">

    <div class="max-sm:!px-[24px]">
      {% if section.settings.heading != blank %}
        <h2 class="glc-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="glc-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="glc-grid flex items-stretch gap-[44px] max-xl:gap-[30px] max-sm:gap-0 max-990:flex-wrap">

      <!-- =========================
        WITH GOLF LIVE (GREEN)
      ========================= -->
      <div
        class="glc-card glc-green 990:w-1/2 w-full relative bg-cover bg-top bg-no-repeat overflow-hidden pr-9 py-14 pl-0 rounded-[28px]"
        style="{% if section.settings.green_bg != blank %}background-image:url({{ section.settings.green_bg | image_url }});{% endif %}"
      >

        <div class="flex items-center gap-[23px] w-full glc-reverse">

          <!-- PHONE DESKTOP -->
          {% if section.settings.green_phone != blank %}
            <div class="glc-phone glc-phone--desktop w-[45%] max-sm:w-1/2">
              {{
                section.settings.green_phone
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 100vw, 45vw',
                  alt: 'With Golf Live App'
              }}
            </div>
          {% endif %}

          <!-- PHONE MOBILE -->
          {% if section.settings.green_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile w-[45%] max-sm:w-1/2">
              {{
                section.settings.green_phone_mobile
                | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,500',
                  sizes: '100vw',
                  alt: 'With Golf Live App'
              }}
            </div>
          {% endif %}

          <!-- TEXT -->
          <div class="glc-phone-sibling flex flex-col w-3/5 max-sm:w-1/2 text-white text-left mt-[80px] max-sm:mt-[20px]">

            <h3 class="glc-card-title text-white">
              {{ section.settings.green_title }}
            </h3>

            <ul class="glc-list mt-[32px]">
              {% for block in section.blocks %}
                {% if block.type == 'with_item' %}
                  <li class="glc-item glc-item--check text-white flex gap-3 items-start" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      {{
                        block.settings.icon
                        | image_url: width: 40
                        | image_tag:
                          loading: 'lazy',
                          widths: '40,60',
                          sizes: '40px',
                          alt: ''
                      }}
                    {% endif %}
                    <span>{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

          </div>
        </div>
      </div>

      <!-- =========================
        WITHOUT GOLF LIVE (GREY)
      ========================= -->
      <div
        class="glc-card glc-grey 990:w-1/2 w-full relative bg-cover bg-top bg-no-repeat overflow-hidden pl-[50px] max-xl:pl-[22px] py-12 pr-0 rounded-[28px]"
        style="{% if section.settings.grey_bg != blank %}background-image:url({{ section.settings.grey_bg | image_url }});{% endif %}"
      >

        <div class="flex items-center gap-[23px] w-full">

          <!-- TEXT -->
          <div class="glc-phone-sibling flex flex-col w-3/5 max-sm:w-1/2 text-left mt-[80px] max-sm:mt-[20px]">

            <h3 class="glc-card-title text-black">
              {{ section.settings.grey_title }}
            </h3>

            <ul class="glc-list mt-[32px]">
              {% for block in section.blocks %}
                {% if block.type == 'without_item' %}
                  <li class="glc-item glc-item--cross flex gap-3 items-start" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}
                      {{
                        block.settings.icon
                        | image_url: width: 40
                        | image_tag:
                          loading: 'lazy',
                          widths: '40,60',
                          sizes: '40px',
                          alt: ''
                      }}
                    {% endif %}
                    <span class="text-black">{{ block.settings.text }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

          </div>

          <!-- PHONE DESKTOP -->
          {% if section.settings.grey_phone != blank %}
            <div class="glc-phone glc-phone--desktop w-[45%] max-sm:w-1/2">
              {{
                section.settings.grey_phone
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  sizes: '(max-width: 768px) 100vw, 45vw',
                  alt: 'Without Golf Live'
              }}
            </div>
          {% endif %}

          <!-- PHONE MOBILE -->
          {% if section.settings.grey_phone_mobile != blank %}
            <div class="glc-phone glc-phone--mobile w-[45%] max-sm:w-1/2">
              {{
                section.settings.grey_phone_mobile
                | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,500',
                  sizes: '100vw',
                  alt: 'Without Golf Live'
              }}
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Golf Live Comparison",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading" },
    { "type": "textarea", "id": "subheading", "label": "Section Subheading" },
    { "type": "image_picker", "id": "green_bg", "label": "Green Background Image" },
    { "type": "image_picker", "id": "green_phone", "label": "Green Phone Image" },
    { "type": "image_picker", "id": "green_phone_mobile", "label": "Green Phone Image (Mobile)" },
    { "type": "text", "id": "green_title", "label": "Green Column Title" },
    { "type": "image_picker", "id": "grey_bg", "label": "Grey Background Image" },
    { "type": "image_picker", "id": "grey_phone", "label": "Grey Phone Image" },
    { "type": "image_picker", "id": "grey_phone_mobile", "label": "Grey Phone Image (Mobile)" },
    { "type": "text", "id": "grey_title", "label": "Grey Column Title" }
  ],
  "blocks": [
    {
      "type": "with_item",
      "name": "With Golf Live Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon Image" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "without_item",
      "name": "Without Golf Live Item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon Image" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Live Comparison" }
  ]
}
{% endschema %}