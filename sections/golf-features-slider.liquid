<div class="golf-features-section bg-[#EFEFEF] relative 
{% if section.settings.section_width == 'full-width' %}w-full px-[20px] min-990:px-[60px]{% else %}page-width{% endif %}
pt-[46px] min-990:pt-[68px] pb-[65px] min-990:pb-[96px]">

  {% if section.settings.desktop_bg != blank %}
    <img
      src="{{ section.settings.desktop_bg | image_url }}"
      alt="Lines"
      loading="lazy"
      width="auto"
      height="auto"
      class="absolute w-full h-full top-0 left-0 pointer-events-none max-990:hidden"
    >
  {% endif %}

  {% if section.settings.mobile_bg != blank %}
    <img
      src="{{ section.settings.mobile_bg | image_url }}"
      alt="Lines"
      loading="lazy"
      width="auto"
      height="auto"
      class="absolute w-full h-full top-0 left-0 pointer-events-none min-990:hidden"
    >
  {% endif %}

  <div class="relative z-1">

    <!-- HEADING -->
    <div class="golf-features-heading text-center">
      {% if section.settings.heading != blank %}
        <h2 class="max-w-[337px] min-1440:max-w-[937px] mx-auto">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="text-h6 font-medium min-990:font-semibold min-990:max-w-[620px] mx-auto mt-[13px] min-990:mt-[24px]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    {% assign desktop_slider = section.settings.enable_slider_desktop %}
    {% assign mobile_slider = section.settings.enable_slider_mobile %}

    <!-- SLIDER -->
    <div class="golf-features-slider-wrapper relative mt-[35px] min-990:mt-[66px]">

      {% if desktop_slider or mobile_slider %}
        <button class="golf-features-arrow-common golf-features-prev swiper-button-prev !left-[-24px] min-1440:!left-[-70px]" type="button">
          {% render 'slider-arrow-golf-pre' %}
        </button>

        <button class="golf-features-arrow-common golf-features-next swiper-button-next !right-[-24px] min-1440:!right-[-70px]" type="button">
          {% render 'slider-arrow-golf-next' %}
        </button>
      {% endif %}

      <div
        class="{% if desktop_slider or mobile_slider %}golf-features-swiper swiper{% else %}golf-features-grid grid grid-cols-1 min-990:grid-cols-{{ section.settings.slides_desktop | round }} gap-[30px]{% endif %}"
        data-desktop-slider="{{ desktop_slider }}"
        data-mobile-slider="{{ mobile_slider }}"
        data-mobile-slides="{{ section.settings.slides_mobile }}"
        data-desktop-slides="{{ section.settings.slides_desktop }}"
      >

        <div class="{% if desktop_slider or mobile_slider %}swiper-wrapper{% endif %}">

          {% for block in section.blocks %}
            <div
              class="{% if desktop_slider or mobile_slider %}swiper-slide !h-auto{% endif %}"
              {{ block.shopify_attributes }}
            >

              <div class="golf-feature-card bg-white rounded-[22px] h-full">

                <!-- IMAGE (UNCHANGED STYLE) -->
                <div class="golf-feature-image">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                      width="auto"
                      height="auto"
                    >
                  {% endif %}
                </div>

                <!-- CONTENT (UNCHANGED) -->
                <div class="golf-feature-content rounded-b-[22px]">

                  <div class="pt-[29px] min-990:pt-[43px] pb-0 pl-[28px] pr-[24px] min-990:px-[38px]">
                    {% if block.settings.title != blank %}
                      <h4>{{ block.settings.title }}</h4>
                    {% endif %}

                    {% if block.settings.description != blank %}
                      <div class="golf-feature-content-subtitle font-semibold text-[17px] leading-[26px] tracking-[0.17px] min-990:text-[19px] min-990:leading-[29px] min-990:tracking-[0.19px] mt-[6px] min-990:mt-[9px]">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="pt-[15px] min-990:pt-[25px] pb-[27px] min-990:pb-[23px] pl-[28px] pr-[24px] min-990:px-[38px] border-b-[1px] border-solid border-[#DFDFDF]">
                    {% if block.settings.coach_description != blank %}
                      <span class="golf-pill block w-fit font-bold text-[14px] leading-[18px] tracking-[0.14px] min-990:text-[17px] min-990:leading-[22px] min-990:tracking-[0.17px] text-white py-[2px] px-[12px] rounded-[50px] bg-green3 mb-[5px]">
                        {{ block.settings.coach_text }}
                      </span>
                      <p class="min-990:text-black2 font-medium">
                        {{ block.settings.coach_description }}
                      </p>
                    {% endif %}
                  </div>

                  <div class="pt-[21px] min-990:pt-[19px] pb-[32px] min-990:pb-[35px] pl-[28px] pr-[24px] min-990:px-[38px]">
                    {% if block.settings.golfer_description != blank %}
                      <span class="golf-pill block w-fit font-bold text-[14px] leading-[18px] tracking-[0.14px] min-990:text-[17px] min-990:leading-[22px] min-990:tracking-[0.17px] text-white py-[2px] px-[12px] rounded-[50px] bg-green3 mb-[8px]">
                        {{ block.settings.golfer_text }}
                      </span>
                      <p class="min-990:text-black2 font-medium">
                        {{ block.settings.golfer_description }}
                      </p>
                    {% endif %}
                  </div>

                </div>

              </div>

            </div>
          {% endfor %}

        </div>
      </div>
    </div>
  </div>
</div>

{% javascript %}
(function () {

  function initSliders() {

    document.querySelectorAll('.golf-features-section').forEach((section) => {

      const swiperEl = section.querySelector('.golf-features-swiper');
      if (!swiperEl || typeof Swiper === 'undefined') return;

      const mobileSlides = parseFloat(swiperEl.dataset.mobileSlides);
      const desktopSlides = parseFloat(swiperEl.dataset.desktopSlides);

      const enableDesktop = swiperEl.dataset.desktopSlider === 'true';
      const enableMobile = swiperEl.dataset.mobileSlider === 'true';

      let swiperInstance = swiperEl.swiperInstance || null;

      function setup() {
        const isMobile = window.matchMedia('(max-width: 639px)').matches;
        const shouldEnable = (isMobile && enableMobile) || (!isMobile && enableDesktop);

        if (shouldEnable) {
          if (!swiperInstance) {
            swiperInstance = new Swiper(swiperEl, {
              spaceBetween: 30,
              loop: true,
              navigation: {
                nextEl: section.querySelector('.golf-features-next'),
                prevEl: section.querySelector('.golf-features-prev'),
              },
              breakpoints: {
                0: { slidesPerView: mobileSlides },
                990: { slidesPerView: desktopSlides }
              }
            });

            swiperEl.swiperInstance = swiperInstance;
          }
        } else {
          if (swiperInstance) {
            swiperInstance.destroy(true, true);
            swiperInstance = null;
            swiperEl.swiperInstance = null;
          }
        }
      }

      setup();
      window.addEventListener('resize', setup);

    });
  }

  document.addEventListener('DOMContentLoaded', initSliders);
  document.addEventListener('shopify:section:load', initSliders);

})();
{% endjavascript %}