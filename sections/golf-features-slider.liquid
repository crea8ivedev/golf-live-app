<div class="golf-features-section bg-[#EFEFEF] relative 
{% if section.settings.section_width == 'full-width' %}w-full px-[20px] min-990:px-[60px]{% else %}page-width{% endif %}
pt-[46px] min-990:pt-[68px] pb-[65px] min-990:pb-[96px]">

  <!-- BACKGROUND -->
  {% if section.settings.desktop_bg != blank %}
    <img
      src="{{ section.settings.desktop_bg | image_url: width: 2000 }}"
      alt="Background"
      loading="lazy"
      width="2000"
      height="1200"
      class="absolute w-full h-full top-0 left-0 object-cover pointer-events-none max-990:hidden"
    >
  {% endif %}

  {% if section.settings.mobile_bg != blank %}
    <img
      src="{{ section.settings.mobile_bg | image_url: width: 800 }}"
      alt="Background"
      loading="lazy"
      width="800"
      height="1200"
      class="absolute w-full h-full top-0 left-0 object-cover pointer-events-none min-990:hidden"
    >
  {% endif %}

  <div class="relative z-1">

    <!-- HEADING -->
    <div class="golf-features-heading text-center">
      {% if section.settings.heading != blank %}
        <h2 class="max-w-[900px] mx-auto">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="text-h6 font-medium min-990:font-semibold max-w-[620px] mx-auto mt-[16px]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    {% assign desktop_slider = section.settings.enable_slider_desktop %}
    {% assign mobile_slider = section.settings.enable_slider_mobile %}

    <!-- SLIDER WRAPPER -->
    <div class="golf-features-slider-wrapper relative mt-[40px] min-990:mt-[70px]">

      {% if desktop_slider or mobile_slider %}
        <button class="golf-features-prev absolute left-[-20px] min-1440:left-[-60px] top-1/2 -translate-y-1/2 z-10" type="button">
          {% render 'slider-arrow-golf-pre' %}
        </button>

        <button class="golf-features-next absolute right-[-20px] min-1440:right-[-60px] top-1/2 -translate-y-1/2 z-10" type="button">
          {% render 'slider-arrow-golf-next' %}
        </button>
      {% endif %}

      <!-- MAIN WRAPPER -->
      <div
        class="{% if desktop_slider or mobile_slider %}golf-features-swiper swiper{% else %}grid grid-cols-1 min-990:grid-cols-{{ section.settings.slides_desktop | round }} gap-[30px]{% endif %}"
        data-desktop-slider="{{ desktop_slider }}"
        data-mobile-slider="{{ mobile_slider }}"
        data-mobile-slides="{{ section.settings.slides_mobile }}"
        data-desktop-slides="{{ section.settings.slides_desktop }}"
      >

        <div class="{% if desktop_slider or mobile_slider %}swiper-wrapper{% endif %}">

          {% for block in section.blocks %}
            <div class="{% if desktop_slider or mobile_slider %}swiper-slide{% endif %}" {{ block.shopify_attributes }}>

              <div class="golf-feature-card bg-white rounded-[22px] h-full max-w-[900px] mx-auto overflow-hidden transition-all duration-300 hover:-translate-y-2">

                <!-- IMAGE -->
                <div class="golf-feature-image">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                      width="600"
                      height="400"
                      style="width:100%; height:auto; max-height:420px; object-fit:cover;"
                    >
                  {% endif %}
                </div>

                <!-- CONTENT -->
                <div class="golf-feature-content">

                  <div class="pt-[28px] min-990:pt-[40px] px-[28px] min-990:px-[36px]">
                    {% if block.settings.title != blank %}
                      <h4>{{ block.settings.title }}</h4>
                    {% endif %}

                    {% if block.settings.description != blank %}
                      <div class="font-semibold text-[17px] min-990:text-[19px] mt-[8px]">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="pt-[20px] pb-[20px] px-[28px] min-990:px-[36px] border-b border-[#DFDFDF]">
                    {% if block.settings.coach_description != blank %}
                      <span class="golf-pill bg-green3 text-white text-[14px] px-[12px] py-[3px] rounded-full mb-[6px] inline-block">
                        {{ block.settings.coach_text }}
                      </span>
                      <p class="text-black2 font-medium">
                        {{ block.settings.coach_description }}
                      </p>
                    {% endif %}
                  </div>

                  <div class="pt-[20px] pb-[30px] px-[28px] min-990:px-[36px]">
                    {% if block.settings.golfer_description != blank %}
                      <span class="golf-pill bg-green3 text-white text-[14px] px-[12px] py-[3px] rounded-full mb-[6px] inline-block">
                        {{ block.settings.golfer_text }}
                      </span>
                      <p class="text-black2 font-medium">
                        {{ block.settings.golfer_description }}
                      </p>
                    {% endif %}
                  </div>

                </div>

              </div>

            </div>
          {% endfor %}

        </div>
      </div>

    </div>
  </div>
</div>

{% javascript %}
(function () {

  function initSliders() {

    document.querySelectorAll('.golf-features-section').forEach((section) => {

      const swiperEl = section.querySelector('.golf-features-swiper');
      if (!swiperEl || typeof Swiper === 'undefined') return;

      const mobileSlides = parseFloat(swiperEl.dataset.mobileSlides);
      const desktopSlides = parseFloat(swiperEl.dataset.desktopSlides);

      const enableDesktop = swiperEl.dataset.desktopSlider === 'true';
      const enableMobile = swiperEl.dataset.mobileSlider === 'true';

      let swiperInstance = swiperEl.swiperInstance || null;

      function setup() {
        const isMobile = window.matchMedia('(max-width: 639px)').matches;
        const shouldEnable = (isMobile && enableMobile) || (!isMobile && enableDesktop);

        if (shouldEnable) {
          if (!swiperInstance) {
            swiperInstance = new Swiper(swiperEl, {
              loop: true,
              spaceBetween: 30,
              navigation: {
                nextEl: section.querySelector('.golf-features-next'),
                prevEl: section.querySelector('.golf-features-prev'),
              },
              breakpoints: {
                0: {
                  slidesPerView: mobileSlides,
                  spaceBetween: 20
                },
                990: {
                  slidesPerView: desktopSlides,
                  spaceBetween: 30
                }
              }
            });

            swiperEl.swiperInstance = swiperInstance;
          }
        } else {
          if (swiperInstance) {
            swiperInstance.destroy(true, true);
            swiperInstance = null;
            swiperEl.swiperInstance = null;
          }
        }
      }

      setup();
      window.addEventListener('resize', setup);

    });
  }

  document.addEventListener('DOMContentLoaded', initSliders);
  document.addEventListener('shopify:section:load', initSliders);

})();
{% endjavascript %}

{% schema %}
{
  "name": "Golf Features",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "page-width", "label": "Contained" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "page-width"
    },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop BG"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile BG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "enable_slider_desktop",
      "label": "Enable slider on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_slider_mobile",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Mobile cards per view",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Desktop cards per view",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "default": 1.5
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "text", "id": "coach_text", "label": "Coach label", "default": "For Coaches" },
        { "type": "textarea", "id": "coach_description", "label": "Coach description" },
        { "type": "text", "id": "golfer_text", "label": "Golfer label", "default": "For Golfers" },
        { "type": "textarea", "id": "golfer_description", "label": "Golfer description" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Features" }
  ]
}
{% endschema %}