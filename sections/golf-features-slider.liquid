<div 
  class="golf-features-section bg-[#EFEFEF] relative {{ section.settings.section_width }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow:hidden;
  "
>

  <!-- DESKTOP BG -->
  {% if section.settings.desktop_bg != blank %}
    <div class="absolute inset-0 pointer-events-none max-990:hidden z-0">
      <img
        src="{{ section.settings.desktop_bg | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="1600"
        height="800"
        style="width:100%; height:100%; object-fit:cover;"
      >
    </div>
  {% endif %}

  <!-- MOBILE BG -->
  {% if section.settings.mobile_bg != blank %}
    <div class="absolute inset-0 pointer-events-none min-990:hidden z-0">
      <img
        src="{{ section.settings.mobile_bg | image_url: width: 800 }}"
        alt=""
        loading="lazy"
        width="800"
        height="1200"
        style="width:100%; height:100%; object-fit:cover;"
      >
    </div>
  {% endif %}

  <div class="relative z-1">

    <!-- HEADER -->
    <div 
      class="golf-features-heading"
      style="
        text-align: {{ section.settings.header_alignment }};
        max-width: {{ section.settings.header_max_width }}px;
        margin-left: auto;
        margin-right: auto;
        padding-top: {{ section.settings.header_padding_top }}px;
        padding-bottom: {{ section.settings.header_padding_bottom }}px;
      "
    >
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="golf-subhead">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <!-- GRID -->
    <div 
      class="golf-features-grid"
      style="
        --desktop-cols: {{ section.settings.cards_desktop }};
        --mobile-cols: {{ section.settings.cards_mobile }};
      "
    >

      {% for block in section.blocks %}

        <div class="golf-feature-card">

          <!-- IMAGE -->
          <div class="golf-feature-image">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {% endif %}
          </div>

          <!-- CONTENT -->
          <div class="golf-feature-content">

            <div class="golf-feature-top">
              {% if block.settings.title != blank %}
                <h4>{{ block.settings.title }}</h4>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class="golf-sub">
                  {{ block.settings.description }}
                </div>
              {% endif %}
            </div>

            {% if block.settings.coach_description != blank %}
              <div class="golf-divider"></div>
              <span class="golf-pill">{{ block.settings.coach_text }}</span>
              <p class="golf-desc">{{ block.settings.coach_description }}</p>
            {% endif %}

            {% if block.settings.golfer_description != blank %}
              <div class="golf-divider"></div>
              <span class="golf-pill">{{ block.settings.golfer_text }}</span>
              <p class="golf-desc">{{ block.settings.golfer_description }}</p>
            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

  </div>
</div>

{% stylesheet %}

/* GRID BASE */
.golf-features-grid {
  display: grid;
  gap: 40px;
  justify-content: center;
}

/* DESKTOP (supports 1–4 cleanly) */
@media (min-width: 990px) {
  .golf-features-grid {
    grid-template-columns: repeat(var(--desktop-cols), 1fr);
    max-width: 1200px;
    margin: 0 auto;
  }
}

/* MOBILE */
@media (max-width: 989px) {
  .golf-features-grid {
    grid-template-columns: repeat(var(--mobile-cols), 1fr);
    gap: 24px;
  }
}

/* CARD */
.golf-feature-card {
  background: white;
  border-radius: 22px;
  overflow: hidden;
  transition: all 0.25s ease;
}

.golf-feature-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 35px rgba(0,0,0,0.08);
}

/* IMAGE */
.golf-feature-image {
  aspect-ratio: 16/10;
  overflow: hidden;
}

.golf-feature-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* CONTENT */
.golf-feature-content {
  padding: 28px;
}

/* TEXT */
.golf-feature-top h4 {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 6px;
}

.golf-sub {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
}

.golf-subhead {
  font-size: 18px;
  margin-top: 20px;
  color: #555;
}

/* DIVIDER */
.golf-divider {
  border-top: 1px solid #e5e5e5;
  margin: 16px 0;
}

/* PILL */
.golf-pill {
  display: inline-block;
  background: #2f6f3e;
  color: white;
  font-size: 13px;
  padding: 4px 12px;
  border-radius: 999px;
  margin-bottom: 8px;
}

/* DESC */
.golf-desc {
  font-size: 15px;
  line-height: 1.5;
  color: #444;
}

/* WIDTH CONTROL */
.golf-features-section.page-width {
  max-width: 1200px;
  margin: 0 auto;
}

.golf-features-section.full-width {
  max-width: 100%;
  padding-left: 40px;
  padding-right: 40px;
}

{% endstylesheet %}

{% schema %}
{
  "name": "Golf Features",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "page-width", "label": "Contained" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "cards_desktop",
      "label": "Cards per row (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cards_mobile",
      "label": "Cards per row (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header Alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "header_max_width",
      "label": "Header Max Width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section Top Padding",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section Bottom Padding",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 100
    },
    {
      "type": "range",
      "id": "header_padding_top",
      "label": "Header Padding Top",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 20
    },
    {
      "type": "range",
      "id": "header_padding_bottom",
      "label": "Header Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 50
    },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop BG"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile BG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "text", "id": "coach_text", "label": "Coach label", "default": "For Coaches" },
        { "type": "textarea", "id": "coach_description", "label": "Coach description" },
        { "type": "text", "id": "golfer_text", "label": "Golfer label", "default": "For Golfers" },
        { "type": "textarea", "id": "golfer_description", "label": "Golfer description" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Features" }
  ]
}
{% endschema %}