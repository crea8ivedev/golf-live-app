<div class="golf-features-section bg-[#EFEFEF] relative page-width pt-[46px] min-990:pt-[68px] pb-[65px] min-990:pb-[96px]">
  {% if section.settings.desktop_bg != blank %}
    <img
      src="{{ section.settings.desktop_bg | image_url }}"
      alt="Lines"
      loading="lazy"
      class="absolute w-full h-full top-0 left-0 pointer-events-none"
    >
  {% endif %}

  {% if section.settings.mobile_bg != blank %}
    <img
      src="{{ section.settings.mobile_bg | image_url }}"
      alt="Lines"
      loading="lazy"
      class="absolute w-full h-full top-0 left-0 pointer-events-none min-990:hidden"
    >
  {% endif %}

  <div class="relative z-1">
    <div class="golf-features-heading text-center">
      {% if section.settings.heading != blank %}
        <h2 class="max-w-[337px] min-1440:max-w-[937px] mx-auto">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="text-h6 font-medium min-990:font-semibold min-990:max-w-[620px] mx-auto mt-[13px] min-990:mt-[24px]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    {% assign desktop_slider = section.settings.enable_slider_desktop %}
    {% assign mobile_slider = section.settings.enable_slider_mobile %}

    <div class="golf-features-slider-wrapper relative mt-[35px] min-990:mt-[66px]">

      {% if desktop_slider or mobile_slider %}
        <button class="golf-features-arrow-common golf-features-prev swiper-button-prev !left-[-24px] min-1440:!left-[-70px]" type="button">
          {% render 'slider-arrow-golf-pre' %}
        </button>

        <button class="golf-features-arrow-common golf-features-next swiper-button-next !right-[-24px] min-1440:!right-[-70px]" type="button">
          {% render 'slider-arrow-golf-next' %}
        </button>
      {% endif %}

      <div
        class="{% if desktop_slider or mobile_slider %}golf-features-swiper swiper{% endif %}"
        data-desktop-slider="{{ desktop_slider }}"
        data-mobile-slider="{{ mobile_slider }}"
      >
        <div class="{% if desktop_slider or mobile_slider %}swiper-wrapper{% else %}golf-features-grid{% endif %}">

          {% for block in section.blocks %}
            <div
              class="{% if desktop_slider or mobile_slider %}swiper-slide{% else %}golf-feature-card{% endif %}"
              {{ block.shopify_attributes }}
            >

              <div class="golf-feature-card bg-white rounded-[22px] flex flex-col">

                <!-- IMAGE -->
                <div class="golf-feature-image">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                      class="golf-feature-img"
                    >
                  {% endif %}
                </div>

                <!-- CONTENT -->
                <div class="golf-feature-content rounded-b-[22px] flex flex-col flex-grow">

                  <div class="pt-[29px] min-990:pt-[43px] pb-0 pl-[28px] pr-[24px] min-990:px-[38px]">
                    {% if block.settings.title != blank %}
                      <h4>{{ block.settings.title }}</h4>
                    {% endif %}

                    {% if block.settings.description != blank %}
                      <div class="golf-feature-content-subtitle font-semibold text-[17px] leading-[26px] min-990:text-[19px] min-990:leading-[29px] mt-[6px] min-990:mt-[9px]">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                  </div>

                  <div class="pt-[15px] min-990:pt-[25px] pb-[27px] min-990:pb-[23px] pl-[28px] pr-[24px] min-990:px-[38px] border-b border-[#DFDFDF]">
                    {% if block.settings.coach_description != blank %}
                      <span class="golf-pill block w-fit font-bold text-[14px] min-990:text-[17px] text-white py-[2px] px-[12px] rounded-[50px] bg-green3 mb-[5px]">
                        {{ block.settings.coach_text }}
                      </span>
                      <p class="min-990:text-black2 font-medium">
                        {{ block.settings.coach_description }}
                      </p>
                    {% endif %}
                  </div>

                  <div class="pt-[21px] min-990:pt-[19px] pb-[32px] min-990:pb-[35px] pl-[28px] pr-[24px] min-990:px-[38px]">
                    {% if block.settings.golfer_description != blank %}
                      <span class="golf-pill block w-fit font-bold text-[14px] min-990:text-[17px] text-white py-[2px] px-[12px] rounded-[50px] bg-green3 mb-[8px]">
                        {{ block.settings.golfer_text }}
                      </span>
                      <p class="min-990:text-black2 font-medium">
                        {{ block.settings.golfer_description }}
                      </p>
                    {% endif %}
                  </div>

                </div>
              </div>
            </div>
          {% endfor %}

        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
.golf-feature-image {
  height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.golf-feature-img {
  max-height: 100%;
  width: auto;
  object-fit: contain;
}

.golf-feature-card {
  height: 100%;
}

.golf-feature-content {
  flex-grow: 1;
}
{% endstyle %}

{% javascript %}
(function () {
  const section = document.querySelector('.golf-features-section');
  if (!section) return;

  const swiperEl = section.querySelector('.golf-features-swiper');
  if (!swiperEl || typeof Swiper === 'undefined') return;

  const enableDesktop = swiperEl.dataset.desktopSlider === 'true';
  const enableMobile = swiperEl.dataset.mobileSlider === 'true';

  let swiperInstance = null;

  function init() {
    const isMobile = window.matchMedia('(max-width: 639px)').matches;

    const shouldEnable = (isMobile && enableMobile) || (!isMobile && enableDesktop);

    if (shouldEnable) {
      if (!swiperInstance) {
        swiperInstance = new Swiper(swiperEl, {
          spaceBetween: 46,
          loop: true,
          navigation: {
            nextEl: section.querySelector('.golf-features-next'),
            prevEl: section.querySelector('.golf-features-prev'),
          },
          breakpoints: {
            0: { slidesPerView: 1.5, spaceBetween: 30 },
            990: { slidesPerView: 2 },
            1280: { slidesPerView: 3 },
          },
        });
      }
    } else {
      if (swiperInstance) {
        swiperInstance.destroy(true, true);
        swiperInstance = null;
      }
    }
  }

  init();
  window.addEventListener('resize', init);
})();
{% endjavascript %}