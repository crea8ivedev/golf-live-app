<div class="golf-features-section bg-[#EFEFEF] relative {{ section.settings.section_width }} pt-[46px] min-990:pt-[68px] pb-[65px] min-990:pb-[96px]">

  {% if section.settings.desktop_bg != blank %}
    <div class="absolute inset-0 pointer-events-none max-990:hidden z-0">
      <img
        src="{{ section.settings.desktop_bg | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="1600"
        height="800"
        style="width:100%; height:100%; object-fit:cover;"
      >
    </div>
  {% endif %}

  <div class="relative z-1">

    <!-- HEADING -->
    <div class="text-center mb-[40px]">
      {% if section.settings.heading != blank %}
        <h2 class="max-w-[900px] mx-auto">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="max-w-[620px] mx-auto mt-[16px]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <!-- PREMIUM LAYOUT -->
    <div class="golf-premium-layout">

      {% for block in section.blocks %}

        {% if forloop.first %}
        <!-- FEATURED CARD -->
        <div class="feature-large">

          <div class="card">

            <div class="image large">
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>

            <div class="content">

              <h3>{{ block.settings.title }}</h3>

              <div class="desc">
                {{ block.settings.description }}
              </div>

              <div class="split">
                <div>
                  <span class="pill">{{ block.settings.coach_text }}</span>
                  <p>{{ block.settings.coach_description }}</p>
                </div>
                <div>
                  <span class="pill">{{ block.settings.golfer_text }}</span>
                  <p>{{ block.settings.golfer_description }}</p>
                </div>
              </div>

            </div>

          </div>

        </div>

        {% elsif forloop.index <= 3 %}
        <!-- RIGHT STACK -->
        <div class="feature-small">

          <div class="card">

            <div class="image">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>

            <div class="content small">

              <h4>{{ block.settings.title }}</h4>

              <div class="desc small">
                {{ block.settings.description }}
              </div>

            </div>

          </div>

        </div>

        {% else %}
        <!-- GRID BELOW -->
        <div class="feature-grid">

          <div class="card">

            <div class="image">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            </div>

            <div class="content small">
              <h4>{{ block.settings.title }}</h4>
              <div class="desc small">
                {{ block.settings.description }}
              </div>
            </div>

          </div>

        </div>

        {% endif %}

      {% endfor %}

    </div>

  </div>
</div>

<style>

/* ===== LAYOUT ===== */

.golf-premium-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 30px;
}

.feature-large {
  grid-row: span 2;
}

.feature-small {
  display: block;
}

.feature-grid {
  grid-column: span 1;
}

/* ===== CARD ===== */

.card {
  background: white;
  border-radius: 22px;
  overflow: hidden;
  height: 100%;
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
}

/* ===== IMAGE ===== */

.image {
  aspect-ratio: 4/3;
  overflow: hidden;
}

.image.large {
  aspect-ratio: 16/10;
  max-height: 420px;
}

.image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ===== CONTENT ===== */

.content {
  padding: 28px;
}

.content.small {
  padding: 20px;
}

.content h3 {
  font-size: 26px;
  margin-bottom: 10px;
}

.content h4 {
  font-size: 18px;
  margin-bottom: 6px;
}

.desc {
  font-size: 16px;
  margin-bottom: 16px;
}

.desc.small {
  font-size: 14px;
}

/* ===== PILLS ===== */

.pill {
  display: inline-block;
  background: #2f6f2f;
  color: white;
  padding: 4px 12px;
  border-radius: 50px;
  font-size: 13px;
  margin-bottom: 6px;
}

/* ===== SPLIT ===== */

.split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* ===== RESPONSIVE ===== */

@media (max-width: 989px) {

  .golf-premium-layout {
    grid-template-columns: 1fr;
  }

  .feature-large {
    grid-row: auto;
  }

  .split {
    grid-template-columns: 1fr;
  }

}

</style>

{% schema %}
{
  "name": "Golf Features Premium V2",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "page-width", "label": "Contained" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "full-width"
    },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop BG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "text", "id": "coach_text", "label": "Coach label" },
        { "type": "textarea", "id": "coach_description", "label": "Coach description" },
        { "type": "text", "id": "golfer_text", "label": "Golfer label" },
        { "type": "textarea", "id": "golfer_description", "label": "Golfer description" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Features Premium V2" }
  ]
}
{% endschema %}