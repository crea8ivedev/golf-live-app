<div 
  class="golf-features-section bg-[#EFEFEF] relative {{ section.settings.section_width }} pt-[46px] min-990:pt-[68px] pb-[65px] min-990:pb-[96px]"
  style="overflow:hidden;"
>

  <!-- DESKTOP BG -->
  {% if section.settings.desktop_bg != blank %}
    <div class="absolute inset-0 pointer-events-none max-990:hidden z-0">
      <img
        src="{{ section.settings.desktop_bg | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="1600"
        height="800"
        style="width:100%; height:100%; object-fit:cover;"
      >
    </div>
  {% endif %}

  <!-- MOBILE BG -->
  {% if section.settings.mobile_bg != blank %}
    <div class="absolute inset-0 pointer-events-none min-990:hidden z-0">
      <img
        src="{{ section.settings.mobile_bg | image_url: width: 800 }}"
        alt=""
        loading="lazy"
        width="800"
        height="1200"
        style="width:100%; height:100%; object-fit:cover;"
      >
    </div>
  {% endif %}

  <div class="relative z-1">

    <!-- HEADING -->
    <div class="golf-features-heading text-center">
      {% if section.settings.heading != blank %}
        <h2 class="max-w-[900px] mx-auto">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="text-h6 max-w-[620px] mx-auto mt-[20px]">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <!-- GRID -->
    <div 
      class="golf-features-grid mt-[40px]"
      style="
        --desktop-cols: {{ section.settings.cards_desktop }};
        --mobile-cols: {{ section.settings.cards_mobile }};
      "
    >

      {% for block in section.blocks %}

        <div class="golf-feature-card">

          <!-- IMAGE -->
          <div class="golf-feature-image">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {% endif %}
          </div>

          <!-- CONTENT -->
          <div class="golf-feature-content">

            <div class="golf-feature-top">
              {% if block.settings.title != blank %}
                <h4>{{ block.settings.title }}</h4>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class="golf-sub">
                  {{ block.settings.description }}
                </div>
              {% endif %}
            </div>

            {% if block.settings.coach_description != blank %}
              <div class="golf-divider"></div>

              <span class="golf-pill">
                {{ block.settings.coach_text }}
              </span>

              <p class="golf-desc">
                {{ block.settings.coach_description }}
              </p>
            {% endif %}

            {% if block.settings.golfer_description != blank %}
              <div class="golf-divider"></div>

              <span class="golf-pill">
                {{ block.settings.golfer_text }}
              </span>

              <p class="golf-desc">
                {{ block.settings.golfer_description }}
              </p>
            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Golf Features",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "page-width", "label": "Contained" },
        { "value": "full-width", "label": "Full Width" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "cards_desktop",
      "label": "Cards per row (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cards_mobile",
      "label": "Cards per row (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "image_picker",
      "id": "desktop_bg",
      "label": "Desktop BG"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile BG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "description", "label": "Description" },
        { "type": "text", "id": "coach_text", "label": "Coach label", "default": "For Coaches" },
        { "type": "textarea", "id": "coach_description", "label": "Coach description" },
        { "type": "text", "id": "golfer_text", "label": "Golfer label", "default": "For Golfers" },
        { "type": "textarea", "id": "golfer_description", "label": "Golfer description" }
      ]
    }
  ],
  "presets": [
    { "name": "Golf Features" }
  ]
}
{% endschema %}