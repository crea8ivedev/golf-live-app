                </div>
              {% endif %}
            {% endfor %}
          </div>

          {% if section.settings.button_text_right != blank %}
            <a
              href="{{ section.settings.button_url_right }}"
              class="dual-card__button ctm-button button-green button-svg mt-[33px] max-768:hidden"
            >
              {{ section.settings.button_text_right }}
            </a>
          {% endif %}

        </div>
      </div>
    </div>

  </div>
</div>

