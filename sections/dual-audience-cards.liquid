<div class="dual-audience-section" id="dual-audience-main">
  <div class="dual-audience-grid grid-cols-1 min-990:grid-cols-2">

    <!-- LEFT CARD -->
    <div class="dual-card dual-card--left relative">

      <!-- BACKGROUND -->
      <div class="dual-card-bg dual-card-left-bg absolute w-full h-full top-0 left-0 pointer-events-none">

        {% if section.settings.bg_image_left != blank %}
          <img
            src="{{ section.settings.bg_image_left | image_url: width: 1200 }}"
            srcset="
              {{ section.settings.bg_image_left | image_url: width: 600 }} 600w,
              {{ section.settings.bg_image_left | image_url: width: 900 }} 900w,
              {{ section.settings.bg_image_left | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 990px) 100vw, 50vw"
            alt="bg-img"
            class="max-990:hidden w-full h-full object-cover object-top"
            loading="lazy"
            width="1200"
            height="900"
          >
        {% endif %}

        {% if section.settings.bg_image_left_mobile != blank %}
          <img
            src="{{ section.settings.bg_image_left_mobile | image_url: width: 400 }}"
            srcset="
              {{ section.settings.bg_image_left_mobile | image_url: width: 300 }} 300w,
              {{ section.settings.bg_image_left_mobile | image_url: width: 400 }} 400w,
              {{ section.settings.bg_image_left_mobile | image_url: width: 600 }} 600w
            "
            sizes="100vw"
            alt="bg-img"
            class="min-990:hidden w-full h-full object-cover object-top"
            loading="lazy"
            width="400"
            height="900"
          >
        {% endif %}

      </div>

      <!-- CONTENT -->
      <div
        id="dual-card-left"
        class="dual-card__inner relative z-1 px-[28px] min-990:max-w-[632px] min-990:mx-auto pt-[276px] min-990:pt-[303px] pb-[60px] min-990:pb-[100px]"
      >
        <div class="dual-card__inner-start px-[17px] min-990:px-[28px] pt-[15px] min-990:pt-[26px] pb-[27px] min-990:pb-[66px] bg-white rounded-[22px]">

          <div class="dual-card__inner-above px-[32px] pt-[30px] pb-[35px] rounded-[10px] min-990:rounded-[25px]">

            {% if section.settings.top_label_left != blank %}
              <span class="dual-card__tag">{{ section.settings.top_label_left }}</span>
            {% endif %}

            {% if section.settings.heading_left != blank %}
              <div class="dual-card__heading h3">
                {{ section.settings.heading_left }}
              </div>
            {% endif %}

            {% if section.settings.description_left != blank %}
              <p class="dual-card__description text-h6">
                {{ section.settings.description_left }}
              </p>
            {% endif %}

          </div>

          <!-- FEATURES -->
          <div class="dual-features">
            {% for block in section.blocks %}
              {% if block.settings.position == 'left' %}
                <div class="dual-feature" {{ block.shopify_attributes }}>

                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 80 }}"
                      alt="{{ block.settings.text | escape }}"
                      loading="lazy"
                      width="80"
                      height="80"
                    >
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <span>{{ block.settings.text }}</span>
                  {% endif %}

                </div>
              {% endif %}
            {% endfor %}
          </div>

          {% if section.settings.button_text_left != blank %}
            <a
              href="{{ section.settings.button_url_left }}"
              class="dual-card__button ctm-button button-green button-svg mt-[33px] max-768:hidden"
            >
              {{ section.settings.button_text_left }}
            </a>
          {% endif %}

        </div>
      </div>
    </div>

    <!-- RIGHT CARD -->
    <div class="dual-card dual-card--right relative">

      <!-- BACKGROUND -->
      <div class="dual-card-bg dual-card-right-bg absolute w-full h-full top-0 left-0 pointer-events-none">

