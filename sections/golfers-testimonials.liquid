{% comment %}
  Section: Golfers Testimonials (FINAL FIXED)
{% endcomment %}

<style>
/* =========================
   TEXT (SAFE WHITE)
========================= */
.cg-testimonial__content,
.cg-testimonial__quote,
.cg-testimonial__author,
.cg-testimonial__author strong,
.cg-testimonial__author span {
  color: #ffffff !important;
}

/* =========================
   GRADIENT OVERLAY
========================= */
.cg-testimonial-inside {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
}

.cg-testimonial-inside::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.85) 0%,
    rgba(0,0,0,0.6) 40%,
    rgba(0,0,0,0.15) 70%,
    transparent 100%
  );
  z-index: 1;
}

.cg-testimonial__content {
  position: relative;
  z-index: 2;
}

/* =========================
   IMAGE FIX
========================= */
.cg-testimonial__image img {
  width: 100%;
  height: auto;
  display: block;
}

/* =========================
   REMOVE SWIPER DEFAULT ARROWS
========================= */
.swiper-button-prev::after,
.swiper-button-next::after {
  display: none !important;
}

/* =========================
   CUSTOM ARROWS
========================= */
.golfers-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;

  width: 48px;
  height: 48px;
  border-radius: 50%;

  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(6px);

  display: flex;
  align-items: center;
  justify-content: center;

  cursor: pointer;
  transition: all 0.2s ease;
}

.golfers-arrow:hover {
  transform: translateY(-50%) scale(1.05);
}

.golfers-prev { left: -24px; }
.golfers-next { right: -24px; }

@media (max-width: 768px) {
  .golfers-prev { left: 8px; }
  .golfers-next { right: 8px; }
}

/* =========================
   STARS
========================= */
.cg-testimonial__stars svg {
  fill: #facc15;
}
</style>

<div
  class="cg-testimonials page-width pt-[45px] min-990:pt-[71px] pb-[59px] min-990:pb-[113px] {{ section.settings.extra_class }}"
  data-desktop-slider="{{ section.settings.enable_desktop_slider }}"
  data-mobile-slider="{{ section.settings.enable_mobile_slider }}"
>

  {% if section.settings.heading != blank %}
    <div class="cg-testimonials__heading h2 text-center mb-[37px] min-990:mb-[68px]">
      {{ section.settings.heading }}
    </div>
  {% endif %}

  <div class="cg-testimonials__wrapper relative">

    <!-- CUSTOM ARROWS -->
    <button class="golfers-arrow golfers-prev" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M15 6L9 12L15 18" stroke="#111" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <button class="golfers-arrow golfers-next" type="button">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M9 6L15 12L9 18" stroke="#111" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- SLIDER -->
    <div class="cg-testimonials__grid swiper">

      <div class="swiper-wrapper">

        {% for block in section.blocks %}
          <div class="cg-testimonial swiper-slide" {{ block.shopify_attributes }}>

            <div class="cg-testimonial-inside">

              <!-- CONTENT -->
              <div class="cg-testimonial__content">

                <div>
                  <div class="cg-testimonial__stars">
                    {% render 'golfers-stars' %}
                  </div>

                  {% if block.settings.quote != blank %}
                    <p class="cg-testimonial__quote">
                      {{ block.settings.quote }}
                    </p>
                  {% endif %}
                </div>

                <div class="cg-testimonial__author">
                  {% if block.settings.name != blank %}
                    <strong>{{ block.settings.name }}</strong>
                  {% endif %}
                  {% if block.settings.designation != blank %}
                    <span>{{ block.settings.designation }}</span>
                  {% endif %}
                </div>

              </div>

              <!-- IMAGE -->
              {% if block.settings.image != blank %}
                <div class="cg-testimonial__image">
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400,600,800',
                      sizes: '(max-width: 768px) 100vw, 50vw',
                      alt: block.settings.name
                  }}
                </div>
              {% endif %}

            </div>
          </div>
        {% endfor %}

      </div>

    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  if (typeof Swiper === 'undefined') return;

  new Swiper('.cg-testimonials .swiper', {
    loop: true,
    spaceBetween: 30,

    navigation: {
      nextEl: '.golfers-next',
      prevEl: '.golfers-prev',
    },

    breakpoints: {
      0: {
        slidesPerView: 1.1,
      },
      990: {
        slidesPerView: 1.5,
      },
      1440: {
        slidesPerView: 2,
      }
    }
  });
});
</script>

{% schema %}
{
  "name": "Golfers Testimonials",
  "settings": [
    { "type": "text", "id": "extra_class", "label": "Extra Class" },
    { "type": "richtext", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "designation", "label": "Role" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    { "name": "Golfers Testimonials" }
  ]
}
{% endschema %}