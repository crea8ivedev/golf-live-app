<div class="vt-wrapper">

  <style>
    .vt-wrapper {
      padding: 60px 20px;
    }

    .vt-heading {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 50px;
    }

    /* GRID */
    .vt-grid {
      display: grid;
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* Mobile */
    .vt-grid {
      grid-template-columns: 1fr;
    }

    /* Tablet */
    @media (min-width: 640px) {
      .vt-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* Desktop */
    @media (min-width: 990px) {
      .vt-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
      }
    }

    /* Large */
    @media (min-width: 1280px) {
      .vt-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    /* CARD */
    .vt-card {
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
    }

    .vt-media {
      position: relative;
      aspect-ratio: 16/10;
    }

    .vt-media img,
    .vt-media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* POSTER */
    .vt-poster {
      position: absolute;
      inset: 0;
      cursor: pointer;
      z-index: 2;
    }

    .vt-play {
      position: absolute;
      inset: 0;
      margin: auto;
      width: 60px;
      height: 60px;
      background: rgba(0,0,0,0.6);
      border-radius: 50%;
    }

    /* TEXT */
    .vt-content {
      padding: 16px;
    }

    .vt-content h4 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .vt-content p {
      font-size: 14px;
      color: #666;
    }
  </style>

  {% if section.settings.heading != blank %}
    <h2 class="vt-heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="vt-grid">

    {% for block in section.blocks %}

      <div class="vt-card">

        <div class="vt-media">

          {% if block.settings.video != blank %}

            {{
              block.settings.video
              | video_tag:
                controls: true,
                preload: 'metadata',
                class: 'vt-video'
            }}

            {% if block.settings.image != blank %}
              <div class="vt-poster">
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt=""
                  loading="lazy"
                >
                <div class="vt-play"></div>
              </div>
            {% endif %}

          {% elsif block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt=""
              loading="lazy"
            >
          {% endif %}

        </div>

        <div class="vt-content">
          <h4>{{ block.settings.name }}</h4>
          <p>{{ block.settings.subtitle }}</p>
        </div>

      </div>

    {% endfor %}

  </div>

</div>


<script>
document.addEventListener('DOMContentLoaded', function () {

  function pauseAll() {
    document.querySelectorAll('.vt-video').forEach(v => {
      v.pause();
      v.currentTime = 0;
    });

    document.querySelectorAll('.vt-poster').forEach(p => {
      p.style.display = 'block';
    });
  }

  document.querySelectorAll('.vt-poster').forEach(poster => {
    const video = poster.parentElement.querySelector('video');

    poster.addEventListener('click', () => {
      pauseAll();
      poster.style.display = 'none';
      video.play();
    });
  });

});
</script>