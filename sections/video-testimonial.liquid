<style>
/* ===== GRID LAYOUT ===== */
.vt-grid {
  display: grid;
  gap: 24px;
}

/* Mobile = stacked */
@media (max-width: 989px) {
  .vt-grid {
    grid-template-columns: 1fr;
  }
}

/* Tablet */
@media (min-width: 640px) {
  .vt-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Desktop */
@media (min-width: 990px) {
  .vt-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
}

/* Large desktop */
@media (min-width: 1280px) {
  .vt-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* CARD */
.vt-slide {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
}

/* VIDEO */
.vt-video-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.vt-slide img,
.vt-slide video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  border-radius: 24px;
}

/* POSTER */
.vt-poster {
  position: absolute;
  inset: 0;
  cursor: pointer;
}

.vt-play-btn {
  position: absolute;
  inset: 0;
  margin: auto;
  border: none;
  cursor: pointer;
}

/* TEXT */
.vt-caption {
  margin-top: 12px;
}
</style>


<div class="vt-wrapper pt-[43px] min-990:pt-[94px] pb-[72px] min-990:pb-[98px]">

  <!-- HEADING -->
  {% if section.settings.heading != blank %}
    <h2 class="text-center max-w-[800px] mx-auto mb-[40px]">
      {{ section.settings.heading | replace: '[highlight]', '<span>' | replace: '[/highlight]', '</span>' }}
    </h2>
  {% endif %}

  <!-- GRID -->
  <div class="vt-grid">

    {% for block in section.blocks %}

      <div class="vt-slide">

        {% if block.settings.video != blank %}
          <div class="vt-video-wrapper">

            {{
              block.settings.video
              | video_tag:
                controls: true,
                autoplay: false,
                muted: false,
                loop: false,
                preload: 'metadata',
                class: 'vt-video'
            }}

            {% if block.settings.image != blank %}
              <div class="vt-poster">
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.name | escape }}"
                  loading="lazy"
                >
                <button class="vt-play-btn" type="button">
                  {% render 'video-test-play-icon' %}
                </button>
              </div>
            {% endif %}

          </div>

        {% elsif block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
          >
        {% endif %}

        {% if block.settings.name != blank %}
          <div class="vt-caption">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.subtitle }}</p>
          </div>
        {% endif %}

      </div>

    {% endfor %}

  </div>

</div>


<script>
document.addEventListener('DOMContentLoaded', function () {

  function pauseAllVideos() {
    document.querySelectorAll('.vt-video').forEach(video => {
      video.pause();
      video.currentTime = 0;
    });

    document.querySelectorAll('.vt-poster').forEach(poster => {
      poster.style.display = 'block';
    });
  }

  document.querySelectorAll('.vt-poster').forEach(poster => {
    const wrapper = poster.closest('.vt-video-wrapper');
    const video = wrapper.querySelector('video');

    poster.addEventListener('click', function () {
      pauseAllVideos();

      poster.style.display = 'none';

      video.play().catch(() => {
        poster.style.display = 'block';
      });
    });
  });

  document.querySelectorAll('.vt-video').forEach(video => {
    video.addEventListener('ended', pauseAllVideos);
  });

});
</script>