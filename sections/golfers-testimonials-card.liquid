{% comment %}
  Section: Testimonials Grid (With Images)
{% endcomment %}

<section class="cg-testimonials">
  <div class="cg-testimonials__inner">

    {% if section.settings.heading != blank %}
      <h2 class="cg-testimonials__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="cg-testimonials__grid">

      {% for block in section.blocks %}
        <div class="cg-testimonial" {{ block.shopify_attributes }}>

          <div class="cg-testimonial__card">

            <!-- TEXT SIDE -->
            <div class="cg-testimonial__content">

              <div class="cg-testimonial__stars">
                {% render 'golfers-stars' %}
              </div>

              {% if block.settings.quote != blank %}
                <p class="cg-testimonial__quote">
                  "{{ block.settings.quote }}"
                </p>
              {% endif %}

              <div class="cg-testimonial__author">
                {% if block.settings.name != blank %}
                  <strong>{{ block.settings.name }}</strong>
                {% endif %}
                {% if block.settings.designation != blank %}
                  <span>{{ block.settings.designation }}</span>
                {% endif %}
              </div>

            </div>

            <!-- IMAGE SIDE -->
            {% if block.settings.image != blank or block.settings.mobile_image != blank %}
              <div class="cg-testimonial__image">

                <!-- Desktop -->
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      widths: '300,400,500',
                      sizes: '(min-width: 768px) 250px, 100vw',
                      alt: block.settings.name
                  }}
                {% endif %}

                <!-- Mobile override -->
                {% if block.settings.mobile_image != blank %}
                  {{
                    block.settings.mobile_image
                    | image_url: width: 400
                    | image_tag:
                      class: 'cg-testimonial__image--mobile',
                      loading: 'lazy',
                      widths: '300,400',
                      sizes: '100vw',
                      alt: block.settings.name
                  }}
                {% endif %}

              </div>
            {% endif %}

          </div>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Coaches and Golfers Are Saying"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "designation",
          "label": "Designation / Subtitle"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Testimonials Grid",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}