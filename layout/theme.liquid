<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon != blank %}
      <link rel="icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    <title>
      {{ page_title }}
      {% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <!-- 🔥 CRITICAL: KEEP THIS (Shopify core scripts) -->
    {{ content_for_header }}

    <!-- 🚀 CSS -->
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'application.css' | asset_url | stylesheet_tag }}

    <!-- Lazy CSS -->
    <link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">

    {% if settings.cart_type == 'drawer' %}
      {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
    {% endif %}

    <!-- 🚀 FONT (optimized) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- 🚀 SWIPER (deferred) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.css">
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js"></script>

    <!-- 🚀 Dawn-safe minimal CSS (DO NOT REMOVE VARIABLES) -->
    {% style %}
      html { box-sizing: border-box; }
      *, *:before, *:after { box-sizing: inherit; }

      body {
        margin: 0;
        display: grid;
        grid-template-rows: auto auto 1fr auto;
        min-height: 100vh;
        font-size: 16px;
      }

      /* ✅ CRITICAL: prevents zoom bug */
      :root {
        --font-body-scale: 1;
        --font-heading-scale: 1;
      }
    {% endstyle %}

    <!-- 🚀 CORE SCRIPTS (deferred) -->
    <script src="{{ 'global.js' | asset_url }}" defer></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer></script>
    <script src="{{ 'details-modal.js' | asset_url }}" defer></script>
    <script src="{{ 'search-form.js' | asset_url }}" defer></script>

  </head>

  <body class="gradient">

    <a class="visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% if settings.cart_type == 'drawer' %}
      {% render 'cart-drawer' %}
    {% endif %}

    {% sections 'header-group' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <!-- 🚀 GLOBAL SHOPIFY VARS -->
    <script>
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_url: '{{ routes.cart_url }}'
      };
    </script>

    <!-- 🚀 DELAYED SCRIPTS (analytics-ready) -->
    <script>
      (function() {
        function loadDelayedScripts() {
          if (window.delayedLoaded) return;
          window.delayedLoaded = true;

          // 🔥 Add GA later when ready
          // var ga = document.createElement('script');
          // ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-XXXXXXX';
          // ga.async = true;
          // document.body.appendChild(ga);
        }

        ['click','scroll','mousemove','touchstart'].forEach(function(e) {
          window.addEventListener(e, loadDelayedScripts, { once: true });
        });

        setTimeout(loadDelayedScripts, 4000);
      })();
    </script>

  </body>
</html>