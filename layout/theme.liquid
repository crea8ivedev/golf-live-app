<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
<head>

<!-- Google Analytics (clean + stable) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-J2LKXQ8BHZ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-J2LKXQ8BHZ');
</script>

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="canonical" href="{{ canonical_url }}">

{%- if settings.favicon != blank -%}
<link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}">
{%- endif -%}

<title>{{ page_title }}</title>

{% if page_description %}
<meta name="description" content="{{ page_description | escape }}">
{% endif %}

{% render 'meta-tags' %}

{{ content_for_header }}

<!-- ✅ PRECONNECT -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- ✅ OPTIMIZED FONT LOAD -->
<link rel="preload" as="style"
href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
onload="this.rel='stylesheet'">

<noscript>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</noscript>

<!-- ✅ CSS (NON BLOCKING) -->
<link rel="preload" href="{{ 'base.css' | asset_url }}" as="style" onload="this.rel='stylesheet'">
<noscript>{{ 'base.css' | asset_url | stylesheet_tag }}</noscript>

<link rel="preload" href="{{ 'application.css' | asset_url }}" as="style" onload="this.rel='stylesheet'">
<noscript>{{ 'application.css' | asset_url | stylesheet_tag }}</noscript>

<link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">

<!-- ✅ SWIPER (DEFERRED CORRECTLY) -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.css"
media="print"
onload="this.media='all'">

<script defer src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js"></script>

<!-- Shopify scripts -->
<script src="{{ 'global.js' | asset_url }}" defer></script>
<script src="{{ 'pubsub.js' | asset_url }}" defer></script>
<script src="{{ 'search-form.js' | asset_url }}" defer></script>

{%- if settings.animations_reveal_on_scroll -%}
<script src="{{ 'animations.js' | asset_url }}" defer></script>
{%- endif -%}

</head>

<body class="gradient">

{% sections 'header-group' %}

<main id="MainContent">
{{ content_for_layout }}
</main>

{% sections 'footer-group' %}

<!-- ✅ HUBSPOT DELAYED LOAD -->
<script>
(function() {
  function loadHubspot() {
    if (window.hsLoaded) return;
    window.hsLoaded = true;

    var hs = document.createElement('script');
    hs.src = 'https://js.hs-scripts.com/YOUR_ID.js';
    hs.async = true;
    document.body.appendChild(hs);
  }

  ['click','scroll','mousemove','touchstart'].forEach(function(e) {
    window.addEventListener(e, loadHubspot, { once: true });
  });

  setTimeout(loadHubspot, 4000);
})();
</script>

</body>
</html>