<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>

<!-- 🔥 GOOGLE TAG (DEFERRED LOAD) -->
<script>
  window.addEventListener('load', function() {
    var s = document.createElement('script');
    s.src = "https://www.googletagmanager.com/gtag/js?id=G-J2LKXQ8BHZ";
    s.async = true;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;

    gtag('js', new Date());
    gtag('config', 'G-J2LKXQ8BHZ');
  });
</script>

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="canonical" href="{{ canonical_url }}">

{%- if settings.favicon != blank -%}
  <link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}">
{%- endif -%}

<title>{{ page_title }}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>

{% if page_description %}
  <meta name="description" content="{{ page_description | escape }}">
{% endif %}

{% render 'meta-tags' %}

{{ content_for_header }}

<!-- 🔥 CRITICAL CSS (KEEP SMALL) -->
<style>
  body {
    margin: 0;
    font-family: var(--font-body-family);
  }

  .vt3-section { padding: 40px 20px; }

  .vt3-heading {
    font-size: 28px;
    font-weight: 700;
    text-align: center;
  }

  /* 🔥 FIX SHOPIFY COLOR SCHEMES */
  [class*="color-"] {
    color: rgba(var(--color-foreground, 0,0,0), 1);
  }

  [class*="color-"] * {
    color: inherit;
  }
</style>

<!-- ✅ KEEP BASE.CSS BLOCKING (CRITICAL) -->
{{ 'base.css' | asset_url | stylesheet_tag }}

<!-- 🚀 NON-BLOCKING CSS -->
<link rel="preload" href="{{ 'application.css' | asset_url }}" as="style" onload="this.rel='stylesheet'">
<noscript>{{ 'application.css' | asset_url | stylesheet_tag }}</noscript>

<!-- OPTIONAL COMPONENT CSS -->
<link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">

<!-- 🔥 FONTS (OPTIMIZED) -->
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" onload="this.rel='stylesheet'">
<noscript>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</noscript>

<!-- 🔥 SCRIPTS (DEFERRED) -->
<script src="{{ 'global.js' | asset_url }}" defer></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer></script>
<script src="{{ 'search-form.js' | asset_url }}" defer></script>

  </head>

<body class="gradient ctm-template-{{ template.name }}">

<a class="visually-hidden" href="#MainContent">Skip to content</a>

{% sections 'header-group' %}

<main id="MainContent">
  {{ content_for_layout }}
</main>

{% sections 'footer-group' %}

<!-- 🔥 GLOBAL JS SETTINGS -->
<script>
window.routes = {
  cart_add_url: '{{ routes.cart_add_url }}',
  cart_url: '{{ routes.cart_url }}'
};
</script>

<!-- 🔥 LAZY LOAD HUBSPOT -->
<script>
(function() {
  function loadHubspot() {
    if (window.hsLoaded) return;
    window.hsLoaded = true;

    var hs = document.createElement('script');
    hs.src = 'https://js.hs-scripts.com/YOUR_ID.js';
    hs.async = true;
    document.body.appendChild(hs);
  }

  ['click','scroll','mousemove','touchstart'].forEach(function(e) {
    window.addEventListener(e, loadHubspot, { once: true });
  });

  setTimeout(loadHubspot, 4000);
})();
</script>

</body>
</html>