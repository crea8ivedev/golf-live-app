<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>

<!-- 🔥 DELAYED GOOGLE ANALYTICS -->
<script>
(function() {
  function loadGA() {
    if (window.gaLoaded) return;
    window.gaLoaded = true;

    var s = document.createElement('script');
    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-J2LKXQ8BHZ';
    s.async = true;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;

    gtag('js', new Date());
    gtag('config', 'G-J2LKXQ8BHZ');
  }

  ['scroll','click','mousemove','touchstart'].forEach(function(e) {
    window.addEventListener(e, loadGA, { once: true });
  });

  setTimeout(loadGA, 3000);
})();
</script>

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="canonical" href="{{ canonical_url }}">

<title>
  {{ page_title }}
  {%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless -%}
</title>

{% if page_description %}
<meta name="description" content="{{ page_description | escape }}">
{% endif %}

{% render 'meta-tags' %}

<!-- 🔥 KEEP SHOPIFY THEME VARIABLES (CRITICAL) -->
{% style %}
  :root {
    --color-foreground: 0,0,0;
    --color-background: 255,255,255;
  }

  body {
    color: rgba(var(--color-foreground),1);
    background-color: rgb(var(--color-background));
  }
{% endstyle %}

<!-- 🔥 SAFETY FALLBACK (FIXES BLACK TEXT ISSUE) -->
<style>
  body {
    color: rgba(var(--color-foreground, 0,0,0), 1);
    background-color: rgb(var(--color-background, 255,255,255));
  }

  section, div, p, h1, h2, h3, h4, h5, h6, span {
    color: inherit;
  }

  .glc-green { color: #fff !important; }
  .glc-grey { color: #111 !important; }

  .text-white { color: #fff !important; }
  .text-black { color: #000 !important; }
</style>

<!-- 🔥 CRITICAL CSS -->
<style>
  body { margin:0; }
  .vt3-section { padding: 40px 20px; }
  .vt3-grid { display:flex; gap:16px; }
  @media (max-width:989px){ .vt3-grid{flex-direction:column;} }
</style>

<!-- ✅ LOAD BASE.CSS NORMALLY (VERY IMPORTANT) -->
{{ 'base.css' | asset_url | stylesheet_tag }}

<!-- 🚀 LAZY LOAD APPLICATION.CSS -->
<link rel="preload" href="{{ 'application.css' | asset_url }}" as="style" onload="this.rel='stylesheet'">
<noscript>{{ 'application.css' | asset_url | stylesheet_tag }}</noscript>

<!-- OPTIONAL CSS -->
<link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">

{{ content_for_header }}

<!-- 🔥 PRELOAD HERO IMAGE -->
<link rel="preload" as="image" href="{{ 'home-banner-bg-mobile.png' | file_url }}" fetchpriority="high">

<!-- 🔥 FONTS (NON-BLOCKING) -->
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link rel="preload" as="style"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
  onload="this.rel='stylesheet'">

<noscript>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</noscript>

<!-- 🔥 SWIPER -->
<link rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.css"
  media="print"
  onload="this.media='all'">

<script defer
  src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js">
</script>

<!-- 🔥 SHOPIFY CORE JS -->
<script src="{{ 'constants.js' | asset_url }}" defer></script>
<script src="{{ 'pubsub.js' | asset_url }}" defer></script>
<script src="{{ 'global.js' | asset_url }}" defer></script>
<script src="{{ 'details-disclosure.js' | asset_url }}" defer></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer></script>
<script src="{{ 'search-form.js' | asset_url }}" defer></script>

  </head>

<body class="gradient{% if template == 'page.golf-live' %} ctm-page-golf-live ctm-page-golf-live-dark{% endif %}">

<a class="skip-to-content-link button visually-hidden" href="#MainContent">
  {{ 'accessibility.skip_to_text' | t }}
</a>

{% sections 'header-group' %}

<main id="MainContent" role="main">
  {{ content_for_layout }}
</main>

{% sections 'footer-group' %}

<!-- 🔥 SHOPIFY GLOBAL DATA -->
<script>
window.shopUrl = '{{ request.origin }}';
window.routes = {
  cart_add_url: '{{ routes.cart_add_url }}',
  cart_change_url: '{{ routes.cart_change_url }}',
  cart_update_url: '{{ routes.cart_update_url }}',
  cart_url: '{{ routes.cart_url }}',
  predictive_search_url: '{{ routes.predictive_search_url }}',
};
</script>

<!-- 🔥 HUBSPOT DELAY -->
<script>
(function() {
  function loadHubspot() {
    if (window.hsLoaded) return;
    window.hsLoaded = true;

    var hs = document.createElement('script');
    hs.src = 'https://js.hs-scripts.com/YOUR_ID.js';
    hs.async = true;
    document.body.appendChild(hs);
  }

  ['click','scroll','mousemove','touchstart'].forEach(function(e) {
    window.addEventListener(e, loadHubspot, { once: true });
  });

  setTimeout(loadHubspot, 4000);
})();
</script>

</body>
</html>